<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg_teal">

    <TextView
        android:id="@+id/widget_streak"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:background="@drawable/widget_chip_bg"
        android:paddingLeft="9dp"
        android:paddingRight="9dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:text="🔥 0" />

    <ImageView
        android:id="@+id/widget_mascot"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="2dp"
        android:src="@drawable/mascot_happy"
        android:contentDescription="Metabole" />

    <TextView
        android:id="@+id/widget_phrase"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:maxLines="3"
        android:ellipsize="end"
        android:text="" />
</LinearLayout>
