<?xml version="1.0" encoding="utf-8"?>
<!-- Copiare in: android/app/src/main/res/layout/metabole_widget.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:text="🌱" />

        <TextView
            android:id="@+id/widget_greeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="#16302C"
            android:textStyle="bold"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Metabole" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_phrase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#5F6E6B"
        android:textSize="12sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="" />

    <TextView
        android:id="@+id/widget_meal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#16302C"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="" />

    <TextView
        android:id="@+id/widget_metrics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#12A386"
        android:textSize="13sp"
        android:text="" />
</LinearLayout>
