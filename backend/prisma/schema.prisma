// Metabole — schema Prisma
// Milestone 1 (Fondamenta): utenti, parametri motore, audit log.
// Riferimento: docs Metabole_Specifica_Backend_Sviluppatore.md (sez. 5, 13, Appendice A)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (runtime)
  directUrl = env("DIRECT_DATABASE_URL") // diretta (solo migrazioni/seed)
}

// --- Enum ---

enum Role {
  client
  coach
  coach_coordinator
  nutritionist
  head_nutritionist
  sales
  marketing
  head_marketing
  admin
}

enum UserStatus {
  active
  suspended
  deleted
}

enum ConfigParamType {
  number
  string
  boolean
  json
}

enum ActionTokenType {
  email_verification
  password_reset
  email_change
}

enum Sex {
  female
  male
}



enum PathType {
  classic3
  five
  supplements
  intermittent_fasting
}

enum CoachStyle {
  daily
  when_needed
  on_request
}

enum Character {
  follows
  needs_push
  perseveres
  quits
}

enum ObjectiveStatus {
  proposed
  confirmed
  achieved
  revised
}

enum EscalationSource {
  screening
  coach
  engine
}

enum EscalationStatus {
  open
  in_progress
  resolved
}

enum Mood {
  great
  good
  ok
  hard
  stressed
}

enum DietStatus {
  draft
  in_review
  approved
  rejected
}

enum ProtocolStatus {
  pending
  approved
  rejected
}

enum EventType {
  wedding
  baptism
  dinner
  monthly_cheat
  vacation
  other
}

enum EventMode {
  single_event
  pause_period
}

enum NotificationChannel {
  inapp
  email
  push
}

enum VisitType {
  in_person
  televisit
}

enum VisitStatus {
  scheduled
  done
  cancelled
}

enum DocumentType {
  blood_test
  photo
  other
}

enum DocumentStatus {
  pending
  reviewed
}

enum ChatCounterpart {
  ai
  coach
  nutritionist
}

enum PaymentMethod {
  manual // acquisto inserito a mano dall'operatore
  bank_transfer
  card
}

enum PaymentStatus {
  pending
  receipt_uploaded
  approved
  rejected
  cancelled
}

enum SubscriptionStatus {
  pending
  active
  cancelled
  expired
}

enum OrderStatus {
  pending
  paid
  cancelled
}

enum LedgerType {
  income
  expense
}

enum MealSlot {
  breakfast
  morning_snack
  lunch
  afternoon_snack
  dinner
}

// --- Modelli ---

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  secondaryEmail  String?    @unique @map("secondary_email") // email alternativa per il login (verificata); notifiche/ricevute vanno sempre alla principale `email`
  passwordHash    String     @map("password_hash")
  mustChangePassword Boolean @default(false) @map("must_change_password") // account creati dall'admin: il frontend forza il cambio password al primo accesso
  role            Role       @default(client)
  customRoleKey   String?    @map("custom_role_key") // ruolo personalizzato (etichetta+menu); il ruolo di sistema resta in `role`
  customRole      CustomRole? @relation(fields: [customRoleKey], references: [key], onDelete: SetNull)
  locale          String     @default("it")
  status          UserStatus @default(active)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")
  prefs           Json?      @map("prefs") // preferenze UI (es. scorciatoie dashboard)
  firstName       String?    @map("first_name")
  lastName        String?    @map("last_name")
  title           String?    // titolo/qualifica mostrata nel backoffice (es. "Coach", "Dr.ssa")
  photoUrl        String?    @map("photo_url") // foto profilo (data URL ridotta) per l'avatar
  theme           String     @default("light") // tema grafico backoffice: light | dark | taupe | white
  addressLine     String?    @map("address_line") // via e numero civico
  postalCode      String?    @map("postal_code")  // CAP
  city            String?
  province        String?
  country         String?    // paese dell'indirizzo (es. Italia, Svizzera)
  phone           String?
  // Utenza COLLEGATA (stessa persona): un'utenza cliente puo' essere legata a una staff
  // (e viceversa, simmetrico) per il "passa all'altro profilo" senza logout. FK-less.
  linkedUserId    String?    @unique @map("linked_user_id")

  auditLogs       AuditLog[]
  configChanges   ConfigParam[] @relation("ConfigUpdatedBy")
  refreshTokens   RefreshToken[]
  actionTokens    ActionToken[]
  staff           Staff?
  clientProfile   ClientProfile?
  objectives      Objective[]
  escalations     Escalation[]
  measurements    Measurement[]
  checkins        DailyCheckin[]
  waterLogs       WaterLog[]
  stepLogs        StepLog[]
  milestones      Milestone[]
  menuDays        MenuDay[]
  recipeRatings   RecipeRating[]
  shoppingLists   ShoppingList[]
  engineDecisions EngineDecision[]
  events          Event[]
  notifications   Notification[]
  visits          Visit[]
  documents       Document[]
  clinicalNotes   ClinicalNote[]
  chatThreads     ChatThread[]
  subscriptions   Subscription[]
  payments        Payment[]
  orders          Order[]
  crmRecord       CrmRecord?
  staffNotes      ClientNote[]
  mailAccount     MailAccount?
  birthDate       DateTime?  @map("birth_date")
  codiceFiscale   String?    @map("codice_fiscale")

  @@index([role])
  pauseRequests         PauseRequest[]
  coachTasks            CoachTask[]
  clientReports         ClientReport[]

  @@map("user")
}

// Scheda dello staff (coach, nutrizionisti, capo, commerciali).
model Staff {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName         String   @map("display_name")
  specialties         String[] @default([])
  bio                 String?
  refCode             String?  @unique @map("ref_code") // codice di riferimento della coach
  iban                String?  // IBAN salvato per i prelievi provvigioni
  headNutritionistId  String?  @map("head_nutritionist_id")
  headNutritionist    Staff?   @relation("NutritionistTeam", fields: [headNutritionistId], references: [id], onDelete: SetNull)
  teamMembers         Staff[]  @relation("NutritionistTeam")
  // Responsabile diretto (un livello sopra) per le provvigioni di catena:
  // per una coach è la manager coach, per un nutrizionista il capo nutrizionista.
  managerId           String?  @map("manager_id")
  manager             Staff?   @relation("StaffManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports             Staff[]  @relation("StaffManager")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  clientsAsCoach        ClientProfile[] @relation("AssignedCoach")
  clientsAsNutritionist ClientProfile[] @relation("AssignedNutritionist")
  escalations           Escalation[]    @relation("EscalationAssignee")
  authoredDiets         Diet[]          @relation("DietAuthor")
  approvedDiets         Diet[]          @relation("DietApprover")
  authoredProtocols     Protocol[]      @relation("ProtocolAuthor")
  validatedProtocols    Protocol[]      @relation("ProtocolValidator")
  visits                Visit[]         @relation("VisitNutritionist")
  reviewedDocuments     Document[]      @relation("DocumentReviewer")
  clinicalNotes         ClinicalNote[]  @relation("NoteAuthor")
  approvedPayments      Payment[]       @relation("PaymentApprover")
  ownedLeads            CrmRecord[]     @relation("LeadOwner")
  coachLeads            CrmRecord[]     @relation("LeadCoach")
  nutritionistLeads     CrmRecord[]     @relation("LeadNutritionist")
  assignedLeads         CrmRecord[]     @relation("LeadAssigner")
  compensations         StaffCompensation[] @relation("CompensationStaff")
  authoredClientNotes   ClientNote[]        @relation("ClientNoteAuthor")
  withdrawals           CommissionWithdrawal[] @relation("StaffWithdrawals")

  crmNotes CrmNote[] @relation("CrmNoteAuthor")

  @@map("staff")
}

/** Richiesta di prelievo delle provvigioni maturate (portafoglio staff). */
model CommissionWithdrawal {
  id           String    @id @default(uuid())
  staffId      String    @map("staff_id")
  staff        Staff     @relation("StaffWithdrawals", fields: [staffId], references: [id], onDelete: Cascade)
  amountCents  Int       @map("amount_cents")
  iban         String
  status       String    @default("requested") // requested | paid | rejected
  receiptData  Bytes?    @map("receipt_data") // ricevuta/fattura caricata (cifrata)
  receiptMime  String?   @map("receipt_mime")
  receiptName  String?   @map("receipt_name")
  note         String?   // motivo del rifiuto o nota dell'operatore
  requestedAt  DateTime  @default(now()) @map("requested_at")
  paidAt       DateTime? @map("paid_at")
  approvedById String?   @map("approved_by_id")

  @@index([staffId, status])
  @@map("commission_withdrawal")
}

// Profilo della cliente: compilato dal questionario di onboarding (15 pagine).
model ClientProfile {
  id                     String     @id @default(uuid())
  userId                 String     @unique @map("user_id")
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                   String?
  age                    Int?
  sex                    Sex?
  heightCm               Int?       @map("height_cm")
  startWeightKg          Float?     @map("start_weight_kg")
  startWaistCm           Float?     @map("start_waist_cm")
  startHipsCm            Float?     @map("start_hips_cm")
  regime                 String?
  dietStyle              String? @map("diet_style")
  mealsPerDay            Int?       @map("meals_per_day")
  // Fase attuale del cliente per l'abbinamento dieta: dimagrimento | mantenimento.
  // Decisione clinica dello staff. Guida pickDiet a scegliere la variante giusta della
  // famiglia (regime × obiettivo). Default dimagrimento: tutti partono in dimagrimento.
  objective              String     @default("dimagrimento")
  pathType               PathType?  @map("path_type")
  coachStyle             CoachStyle? @map("coach_style")
  character              Character?
  allergies              String[]   @default([]) // R8: blocco duro (incl. tracce/derivati), distinto da intolleranze/gusti
  intolerances           String[]   @default([])
  dislikedFoods          String[]   @default([]) @map("disliked_foods")
  lifestyle              Json?      // lavoro, tempo per cucinare, pranzo feriali (segnale "Vita")
  themeColor             String?    @map("theme_color")
  planStartDate          DateTime?  @map("plan_start_date")
  assignedCoachId        String?    @map("assigned_coach_id")
  assignedCoach          Staff?     @relation("AssignedCoach", fields: [assignedCoachId], references: [id], onDelete: SetNull)
  assignedNutritionistId String?    @map("assigned_nutritionist_id")
  assignedNutritionist   Staff?     @relation("AssignedNutritionist", fields: [assignedNutritionistId], references: [id], onDelete: SetNull)
  consents               Json?      // versioni dei consensi accettati
  notificationPrefs      Json?      @map("notification_prefs") // opt-out per tipo + email opzionale
  referralCode           String?    @unique @map("referral_code") // codice "porta un'amica" della cliente
  screeningFlag          Boolean    @default(false) @map("screening_flag")
  onboardingAnswers      Json?      @map("onboarding_answers") // snapshot grezzo delle risposte
  onboardingCompletedAt  DateTime?  @map("onboarding_completed_at")
  // Modalità viaggio/estate (piani stagionali): in_partenza | in_vacanza | rientrato + date.
  travelState            String?    @map("travel_state")
  travelStart            DateTime?  @map("travel_start")
  travelEnd              DateTime?  @map("travel_end")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  @@index([assignedCoachId])
  @@index([assignedNutritionistId])
  @@map("client_profile")
}

// Obiettivo della cliente: creato nel questionario, confermato da coach+nutrizionista,
// riconfermato dopo ogni visita (history).
model Objective {
  id                       String          @id @default(uuid())
  clientId                 String          @map("client_id")
  client                   User            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  targetWeightKg           Float?          @map("target_weight_kg")
  targetWaistCm            Float?          @map("target_waist_cm")
  targetHipsCm             Float?          @map("target_hips_cm")
  targetDate               DateTime?       @map("target_date")
  status                   ObjectiveStatus @default(proposed)
  confirmedByCoachAt       DateTime?       @map("confirmed_by_coach_at")
  confirmedByNutritionistAt DateTime?      @map("confirmed_by_nutritionist_at")
  history                  Json?           // riconferme/revisioni dopo ogni visita
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")

  @@index([clientId])
  @@map("objective")
}

// Presa in carico dei casi da supervisionare (screening, alert coach, motore).
model Escalation {
  id           String           @id @default(uuid())
  clientId     String           @map("client_id")
  client       User             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reason       String
  source       EscalationSource
  // R12 — categoria per il routing al ruolo giusto: diet_blocked | no_progress |
  // low_adherence | mood_risk | clinical | other. Nullable per compatibilità (null = other).
  category     String?          @map("category")
  assignedToId String?          @map("assigned_to_id")
  assignedTo   Staff?           @relation("EscalationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  status       EscalationStatus @default(open)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([status])
  @@map("escalation")
}

// --- CRM, commercio, contabilità (milestone 9) ---

// Piano di abbonamento (prezzi in CENTESIMI: niente virgole mobili sui soldi).
model Plan {
  id          String   @id @default(uuid())
  name        String
  priceCents  Int      @map("price_cents") // prezzo di VENDITA in promo (o unico, se niente listino)
  // Prezzo pieno di listino (barrato, es. €299→€249) + fine della promo "founding":
  // scaduta la promo, il prezzo effettivo torna al listino automaticamente.
  listPriceCents Int?     @map("list_price_cents")
  promoEndsAt    DateTime? @map("promo_ends_at")
  period      String // es. 3m | 6m | 12m
  mealsPerDay Int?     @map("meals_per_day")
  features    String[] @default([])
  active      Boolean  @default(true)
  // Nascosto dallo shop ma acquistabile con link diretto (es. "Menu di rientro" del Monitoraggio).
  hidden      Boolean  @default(false)
  // Se false: dopo l'acquisto il piano scompare dallo shop di QUEL cliente (non riacquistabile).
  repurchasable Boolean @default(true)
  // RETE PROVVIGIONALE A DIFFERENZA (decisione 17/07): percentuali per LIVELLO
  // sull'importo effettivamente pagato. Ognuno incassa la differenza col livello
  // sotto (es. coach 25 / coordinatrice 35 / manager 45 → 25+10+10 a rete completa;
  // coach direttamente sotto la manager → 25+20). Stessa logica per nutrizionista →
  // capo. Se tutte le percentuali sono 0 valgono ancora gli importi fissi sotto.
  commissionCoachPct            Int @default(0) @map("commission_coach_pct")
  commissionCoordinatorPct      Int @default(0) @map("commission_coordinator_pct")
  commissionManagerPct          Int @default(0) @map("commission_manager_pct")
  commissionNutritionistPct     Int @default(0) @map("commission_nutritionist_pct")
  commissionHeadNutritionistPct Int @default(0) @map("commission_head_nutritionist_pct")
  // Provvigioni in CENTESIMI di € per questo piano (importi fissi, LEGACY:
  // usate solo se le percentuali qui sopra sono tutte a zero).
  commissionCoachCents            Int @default(0) @map("commission_coach_cents")
  commissionManagerCoachCents     Int @default(0) @map("commission_manager_coach_cents")
  commissionNutritionistCents     Int @default(0) @map("commission_nutritionist_cents")
  commissionHeadNutritionistCents Int @default(0) @map("commission_head_nutritionist_cents")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plan")
}

model Subscription {
  id        String             @id @default(uuid())
  clientId  String             @map("client_id")
  client    User               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId    String             @map("plan_id")
  plan      Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status    SubscriptionStatus @default(pending)
  startDate DateTime?          @map("start_date")
  endDate   DateTime?          @map("end_date")
  pspRef    String?            @map("psp_ref")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  payments Payment[]

  @@index([clientId, status])
  @@map("subscription")
}

// Pagamento con flusso bonifico: pending → receipt_uploaded → approved|rejected.
// L'abbonamento (e menu/provvigioni) si attiva SOLO all'approvazione dell'operatore.
model Payment {
  id             String        @id @default(uuid())
  clientId       String        @map("client_id")
  client         User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscriptionId String?       @map("subscription_id")
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  orderId        String?       @unique @map("order_id")
  order          Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  amountCents    Int           @map("amount_cents")
  description    String
  method         PaymentMethod @default(bank_transfer)
  status         PaymentStatus @default(pending)
  receiptData    Bytes?        @map("receipt_data") // contabile cifrata AES-256-GCM
  receiptMime    String?       @map("receipt_mime")
  receiptName    String?       @map("receipt_name")
  approvedById   String?       @map("approved_by_id")
  approvedBy     Staff?        @relation("PaymentApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt     DateTime?     @map("approved_at")
  rejectReason   String?       @map("reject_reason")
  pspRef         String?       @map("psp_ref")
  discountCodeId String?       @map("discount_code_id")
  discountCents  Int?          @map("discount_cents")
  refundCents    Int?          @map("refund_cents") // storno registrato (rimborso alla cliente)
  refundedAt     DateTime?     @map("refunded_at")
  refundNote     String?       @map("refund_note")
  refundById     String?       @map("refund_by_id") // user id dell'operatore che ha stornato
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([clientId, createdAt])
  @@map("payment")
}

// Integratori (spec): catalogo minimo.
model Product {
  id          String   @id @default(uuid())
  name        String
  priceCents  Int      @map("price_cents")
  description String?
  active      Boolean  @default(true)
  // Se false: dopo l'acquisto il prodotto scompare dallo shop di QUEL cliente (non riacquistabile).
  repurchasable Boolean @default(true)
  // RETE PROVVIGIONALE A DIFFERENZA (decisione 17/07): percentuali per LIVELLO
  // sull'importo effettivamente pagato. Ognuno incassa la differenza col livello
  // sotto (es. coach 25 / coordinatrice 35 / manager 45 → 25+10+10 a rete completa;
  // coach direttamente sotto la manager → 25+20). Stessa logica per nutrizionista →
  // capo. Se tutte le percentuali sono 0 valgono ancora gli importi fissi sotto.
  commissionCoachPct            Int @default(0) @map("commission_coach_pct")
  commissionCoordinatorPct      Int @default(0) @map("commission_coordinator_pct")
  commissionManagerPct          Int @default(0) @map("commission_manager_pct")
  commissionNutritionistPct     Int @default(0) @map("commission_nutritionist_pct")
  commissionHeadNutritionistPct Int @default(0) @map("commission_head_nutritionist_pct")
  // Provvigioni in CENTESIMI per unità (importi fissi, LEGACY: usate solo se le
  // percentuali qui sopra sono tutte a zero). Riscalate sull'importo pagato.
  commissionCoachCents            Int @default(0) @map("commission_coach_cents")
  commissionManagerCoachCents     Int @default(0) @map("commission_manager_coach_cents")
  commissionNutritionistCents     Int @default(0) @map("commission_nutritionist_cents")
  commissionHeadNutritionistCents Int @default(0) @map("commission_head_nutritionist_cents")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("product")
}

model Order {
  id         String      @id @default(uuid())
  clientId   String      @map("client_id")
  client     User        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status     OrderStatus @default(pending)
  totalCents Int         @map("total_cents")
  items      Json // [{productId, name, priceCents, qty}]
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  payment Payment?

  @@index([clientId])
  @@map("order")
}

// CRM: ogni transizione di stage salva data + responsabile (spec sez. 8).
model CrmRecord {
  id         String   @id @default(uuid())
  clientId   String?  @unique @map("client_id")
  client     User?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  email      String?
  phone      String? // per i lead puri (importati): il telefono è chiave insieme all'email
  name       String?
  stage      String   @default("lead_in") // chiave di pipeline_stage (gestita da admin)
  stageDates Json     @default("{}") @map("stage_dates") // {stage: {at, byUserId}}
  ownerId    String?  @map("owner_id")
  owner      Staff?   @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  valueCents Int?     @map("value_cents")
  // Assegnazione alla coach con accettazione (2 giorni), oppure diretta via ref code.
  assignedCoachId  String?   @map("assigned_coach_id")
  assignedCoach    Staff?    @relation("LeadCoach", fields: [assignedCoachId], references: [id], onDelete: SetNull)
  assignedNutritionistId String? @map("assigned_nutritionist_id")
  assignedNutritionist   Staff?  @relation("LeadNutritionist", fields: [assignedNutritionistId], references: [id], onDelete: SetNull)
  assignmentStatus String?   @map("assignment_status") // pending | accepted
  assignedAt       DateTime? @map("assigned_at")
  assignedById     String?   @map("assigned_by_id")
  assignedBy       Staff?    @relation("LeadAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  // Storico pre-Metabole (dalle liste importate): stato precedente e totale già
  // pagato dal cliente. Solo INFORMATIVI sulla scheda: NON entrano in contabilità.
  previousStatus      String? @map("previous_status")
  historicalPaidCents Int?    @map("historical_paid_cents")
  // Anagrafica fiscale/indirizzo (dalle liste storiche o inserita a mano sulla scheda).
  codiceFiscale String? @map("codice_fiscale")
  address       String? // indirizzo (testo libero: via/città, come nelle liste storiche)
  // Handoff punto 6 — tracciamento e consensi.
  // segment: ex_cliente | lead_caldo | lead_freddo (se vuoto si deriva da storico/stage).
  // channel: canale di provenienza/contatto (email | whatsapp | sms | coach | retargeting | organico).
  segment          String?
  channel          String?
  // Consenso marketing (GDPR): null = mai chiesto (per lo storico serve ri-opt-in),
  // true/false = scelta esplicita; consentChannels = canali autorizzati (email|whatsapp|sms).
  marketingConsent Boolean?  @map("marketing_consent")
  consentChannels  String[]  @default([]) @map("consent_channels")
  consentAt        DateTime? @map("consent_at")
  consentSource    String?   @map("consent_source") // es. form-sito | preferenze | import | operatore
  tags          String[] @default([]) // etichette libere per la segmentazione marketing (es. "mamma", "acquisto-2024")
  reminders  CrmReminder[]
  listMemberships CrmListMember[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([stage])
  @@index([assignedCoachId, assignmentStatus])
  crmNotes CrmNote[]

  @@map("crm_record")
}

// Note dello staff sul LEAD (scheda CRM): come le note cliente, ma agganciate alla
// scheda CRM così valgono anche per i lead puri senza account utente.
model CrmNote {
  id        String    @id @default(uuid())
  recordId  String    @map("record_id")
  record    CrmRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  authorId  String?   @map("author_id")
  author    Staff?    @relation("CrmNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([recordId])
  @@map("crm_note")
}

// Liste CRM: raggruppamenti manuali di lead/clienti (un contatto può stare in più
// liste). Create a mano dall'operatore; usate per filtrare le viste CRM.
model CrmList {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String? // hex opzionale per il badge
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  members     CrmListMember[]

  @@map("crm_list")
}

// Appartenenza N:N tra lead/cliente e lista.
model CrmListMember {
  listId   String    @map("list_id")
  list     CrmList   @relation(fields: [listId], references: [id], onDelete: Cascade)
  recordId String    @map("record_id")
  record   CrmRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  addedAt  DateTime  @default(now()) @map("added_at")

  @@id([listId, recordId])
  @@index([recordId])
  @@map("crm_list_member")
}

// Calendario CRM: promemoria/appuntamenti, opzionalmente legati a un lead/cliente.
model CrmReminder {
  id          String     @id @default(uuid())
  crmRecordId String?    @map("crm_record_id")
  crmRecord   CrmRecord? @relation(fields: [crmRecordId], references: [id], onDelete: SetNull)
  title       String
  dueAt       DateTime   @map("due_at")
  note        String?
  done        Boolean    @default(false)
  createdById String?    @map("created_by_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([dueAt])
  @@index([crmRecordId])
  @@map("crm_reminder")
}

// Stati della pipeline commerciale/clienti, gestibili dall'admin (condivisi).
// La KEY è stabile (usata dall'automazione: lead_in alla registrazione, paid
// all'approvazione pagamento); label/color/order/visibilità sono personalizzabili.
model PipelineStage {
  key       String   @id
  label     String
  color     String?
  order     Int      @default(0)
  isSystem  Boolean  @default(false) @map("is_system") // key referenziata dall'automazione: non eliminabile
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([order])
  @@map("pipeline_stage")
}

// Contabilità: eventi economici automatici, niente doppio inserimento.
// Voce di costo per la contabilità (backlog #6). Registra i costi aziendali oltre a
// quelli già a ledger (provvigioni/compensi): infrastruttura (Neon/Render/Vercel/Brevo/
// Stripe/Anthropic), marketing/ads, stipendi, tasse, ecc. Un costo può essere una tantum
// (`recurring=false`, conta nella sua `date`) o ricorrente (`recurring=true`, `cadence`
// mensile/annuale, attivo da `date` a `endDate`). FK-less.
model CostEntry {
  id          String    @id @default(uuid())
  label       String
  category    String // salaries | infrastructure | marketing | payment_fees | ai | taxes | other
  amountCents Int       @map("amount_cents")
  recurring   Boolean   @default(false)
  cadence     String    @default("once") // once | monthly | yearly
  date        DateTime  @db.Date // una tantum: data del costo · ricorrente: data di inizio
  endDate     DateTime? @map("end_date") @db.Date // ricorrente: fine (opzionale)
  vendor      String?
  note        String?
  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([category, date])
  @@map("cost_entry")
}

model LedgerEntry {
  id        String     @id @default(uuid())
  type      LedgerType
  amountCents Int      @map("amount_cents")
  category  String // subscription | order | sales_commission | visit_compensation | ...
  date      DateTime   @default(now())
  ref       String? // payment/visit id
  clientId  String?    @map("client_id")
  staffId   String?    @map("staff_id")
  note      String?

  @@index([type, date])
  @@index([category, date])
  @@map("ledger_entry")
}

// Compensi/provvigioni dello staff, aggregati per periodo (YYYY-MM).
model StaffCompensation {
  id      String @id @default(uuid())
  staffId String @map("staff_id")
  staff   Staff  @relation("CompensationStaff", fields: [staffId], references: [id], onDelete: Cascade)
  period  String // YYYY-MM
  amountCents Int @default(0) @map("amount_cents")
  items   Json   @default("[]") // [{at, kind, amountCents, ref}]

  @@unique([staffId, period])
  @@map("staff_compensation")
}

// --- Chat (milestone 8) ---

// Un thread per controparte (AI, coach, nutrizionista) per ogni cliente.
model ChatThread {
  id            String          @id @default(uuid())
  clientId      String          @map("client_id")
  client        User            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  counterpart   ChatCounterpart
  lastMessageAt DateTime?       @map("last_message_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  messages Message[]

  @@unique([clientId, counterpart])
  @@map("chat_thread")
}

// senderRole: client | coach | nutritionist | head_nutritionist | ai
// meta: instradamento/filtro (es. {matchedFaq}, {routedTo}, {escalated}, {forwardedFrom}).
model Message {
  id           String     @id @default(uuid())
  threadId     String     @map("thread_id")
  thread       ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderRole   String     @map("sender_role")
  senderUserId String?    @map("sender_user_id")
  body         String
  meta         Json?
  sentAt       DateTime   @default(now()) @map("sent_at")

  @@index([threadId, sentAt])
  @@map("message")
}

// --- Area sanitaria (milestone 7) ---

// Visite: la PRIMA è sempre in presenza (vincolo imposto dal modulo, spec sez. 11);
// la televisita è ammessa solo per i controlli successivi.
model Visit {
  id             String      @id @default(uuid())
  clientId       String      @map("client_id")
  client         User        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nutritionistId String      @map("nutritionist_id")
  nutritionist   Staff       @relation("VisitNutritionist", fields: [nutritionistId], references: [id], onDelete: Restrict)
  type           VisitType
  datetime       DateTime
  status         VisitStatus @default(scheduled)
  notes          String? // RISERVATE: solo nutrizionista e capo
  videoRoomId    String?     @map("video_room_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([clientId, datetime])
  @@index([nutritionistId, datetime])
  @@map("visit")
}

// Documenti sanitari: contenuto cifrato AES-256-GCM nel database (storage UE).
// L'astrazione permetterà la migrazione a bucket S3 senza cambiare le API.
model Document {
  id           String         @id @default(uuid())
  clientId     String         @map("client_id")
  client       User           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type         DocumentType
  fileName     String         @map("file_name")
  mimeType     String         @map("mime_type")
  sizeBytes    Int            @map("size_bytes")
  data         Bytes // iv (12B) + authTag (16B) + ciphertext
  status       DocumentStatus @default(pending)
  flags        String[]       @default([]) // es. "valore fuori range"
  reviewedById String?        @map("reviewed_by_id")
  reviewedBy   Staff?         @relation("DocumentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote   String?        @map("review_note")
  uploadedAt   DateTime       @default(now()) @map("uploaded_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([clientId, uploadedAt])
  @@index([status])
  @@map("document")
}

// Note cliniche: accesso RISERVATO a nutrizionista assegnato e capo. Mai coach, mai admin.
model ClinicalNote {
  id             String   @id @default(uuid())
  clientId       String   @map("client_id")
  client         User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nutritionistId String   @map("nutritionist_id")
  nutritionist   Staff    @relation("NoteAuthor", fields: [nutritionistId], references: [id], onDelete: Restrict)
  text           String
  date           DateTime @default(now())

  @@index([clientId, date])
  @@map("clinical_note")
}

// --- Calendario e notifiche (milestone 6) ---

// Segnale "Agenda": eventi singoli e periodi senza dieta.
// I periodi di pausa sospendono l'erogazione ma il monitoraggio continua:
// oltre pause_deviation_trigger scatta il mini-piano (spec sez. 5/8).
model Event {
  id             String    @id @default(uuid())
  clientId       String    @map("client_id")
  client         User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type           EventType
  label          String?
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime  @map("end_date") @db.Date
  mode           EventMode
  planPhaseState String?   @map("plan_phase_state") // before | during | after | mini_plan_active
  startWeightKg  Float?    @map("start_weight_kg") // peso all'inizio della pausa (per il mini-piano)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([clientId, startDate])
  @@map("event")
}

// Eventi di tracciamento (analitici, append-only). Ogni click/interazione del
// prototipo passa da track() → POST /events. Tabella DISACCOPPIATA: nessuna FK
// verso User (userId è una stringa opzionale) così gli eventi restano immutabili
// e sopravvivono alla cancellazione dell'utente (GDPR: no dati sanitari nel data).
// Vedi Metabole_Tracciamento_Dati.md.
model AnalyticsEvent {
  id         String   @id @default(uuid())
  eventId    String   @unique @map("event_id") // UUID lato client per idempotenza sui retry
  name       String // "ui_click" | "view" | ...
  userId     String?  @map("user_id") // dal JWT se presente (nessuna FK)
  session    String? // sessione pre-login (riconciliata alla registrazione)
  refcod     String? // attribuzione commerciale / provvigioni
  phase      String? // "flow" | "app"
  screen     String?
  step       Int?
  data       Json? // payload libero (MAI dati sanitari in chiaro)
  clientTs   BigInt?  @map("client_ts") // timestamp epoch ms dichiarato dal client
  receivedAt DateTime @default(now()) @map("received_at")

  @@index([userId, receivedAt])
  @@index([session, receivedAt])
  @@index([name, receivedAt])
  @@map("analytics_event")
}

// Alert engine (coda avvisi per la coach). Tabella DISACCOPPIATA (clientId/coachId
// come stringhe, nessuna FK) generata e sincronizzata da AlertsService.recompute:
// gli alert la cui condizione non vale più vengono messi a status='resolved'.
// coachId = Staff.id della coach assegnata. Vedi Metabole_Backend_Operazioni §5.
model Alert {
  id        String    @id @default(uuid())
  clientId  String    @map("client_id")
  coachId   String?   @map("coach_id")
  group     String    @map("alert_group") // corpo_misure | aderenza_vita | gusto_mente | agenda_op
  type      String // missing_measurements | weight_gain | plateau | inactive | checkin_skipped | water_low | low_ratings | dropout_risk | event_incoming | escalation_open | milestone
  priority  String // high | med | low
  title     String
  detail    String?
  status    String    @default("open") // open | handled | escalated | resolved
  dueDate   DateTime? @map("due_date") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([coachId, status])
  @@index([clientId, type, status])
  @@map("alert")
}

// Riassunto giornaliero di una conversazione (chiusura quotidiana): titolo
// generato dall'AI + data, mostrato in "Conversazioni passate" (cliente e staff).
// Vedi Metabole_Backend_Operazioni §7. FK-less sul clientId.
model ConversationSummary {
  id           String          @id @default(uuid())
  clientId     String          @map("client_id")
  counterpart  ChatCounterpart
  date         DateTime        @db.Date
  title        String
  summary      String?
  messageCount Int             @default(0) @map("message_count")
  createdAt    DateTime        @default(now()) @map("created_at")

  @@unique([clientId, counterpart, date])
  @@index([clientId, counterpart, date])
  @@map("conversation_summary")
}

// Esito di un ciclo (2 giorni) del motore: perdita/stabilità/aumento di peso e cm,
// attribuiti all'INTERA giornata/ciclo. Registrato alla chiusura del ciclo (arrivo
// misura al 2° giorno). Vedi Metabole_Motore_Personalizzazione §4. FK-less.
model CycleFeedback {
  id            String   @id @default(uuid())
  clientId      String   @map("client_id")
  cycleStart    DateTime @map("cycle_start") @db.Date
  cycleEnd      DateTime @map("cycle_end") @db.Date
  deltaWeightKg Float?   @map("delta_weight_kg")
  deltaCm       Float?   @map("delta_cm")
  esitoPeso     String   @map("esito_peso") // perso | stabile | preso | n.d.
  esitoCm       String   @map("esito_cm") // perso | stabile | preso | n.d.
  followed      Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([clientId, cycleEnd])
  @@index([clientId, cycleEnd])
  @@map("cycle_feedback")
}

// Livello "Monitoraggio" (spec Antonio 17/07): dopo il percorso la cliente resta
// agganciata GRATIS per max 1 mese; Gaia chiede le misure e, se riprende peso
// (+3 kg parametrizzabile), propone gli 8 menu di rientro a pagamento (€29).
// Se non paga: il monitoraggio si CONGELA (lo storico resta, niente purge).
// FK-less (clientId stringa) come gli altri modelli del motore.
model MonitoringPeriod {
  id                String    @id @default(uuid())
  clientId          String    @map("client_id")
  status            String    @default("active") // active | frozen | expired | converted
  startedAt         DateTime  @default(now()) @map("started_at")
  endsAt            DateTime  @map("ends_at")
  referenceWeightKg Float     @map("reference_weight_kg") // ultimo peso "buono" a fine percorso
  regainOfferedAt   DateTime? @map("regain_offered_at") // quando è stata proposta l'offerta di rientro
  frozenAt          DateTime? @map("frozen_at")
  closedAt          DateTime? @map("closed_at")
  convertedTo       String?   @map("converted_to") // nome piano di conversione (dimagrimento/mantenimento)
  lastMeasureAskAt  DateTime? @map("last_measure_ask_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([clientId, status])
  @@map("monitoring_period")
}

// Efficacia APPRESA di una ricetta per uno specifico cliente (learning del motore):
// sale se i cicli in cui compare fanno perdere peso/cm, scende altrimenti. FK-less.
model MenuWeight {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  recipeId  String   @map("recipe_id")
  score     Float    @default(0)
  samples   Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, recipeId])
  @@index([clientId])
  @@map("menu_weight")
}

// Invito "porta un'amica": una cliente (referrer) invita un'altra cliente (referred)
// col proprio referralCode. Alla prima attivazione dell'abbonamento della referred
// scatta la ricompensa per la referrer (estensione dell'abbonamento). FK-less:
// referrerClientId/referredClientId come stringhe. Una referred = un solo invito.
model Referral {
  id               String    @id @default(uuid())
  referrerClientId String    @map("referrer_client_id")
  referredClientId String    @unique @map("referred_client_id")
  code             String
  convertedAt      DateTime? @map("converted_at") // prima attivazione abbonamento della referred
  rewardedAt       DateTime? @map("rewarded_at") // ricompensa applicata alla referrer
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([referrerClientId])
  @@map("referral")
}

// Appuntamento in agenda (app coach + cliente). Entità di SCHEDULING generale
// (coach e nutrizionista); la visita clinica dettagliata resta su Visit (fase
// nutrizionista). FK-less: clientId/staffId come stringhe. Vedi Metabole_Backend_Operazioni §6.
model Appointment {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  staffId   String   @map("staff_id")
  staffRole String   @map("staff_role") // coach | nutritionist
  type      String // call | televisit | in_person
  datetime  DateTime
  status    String   @default("scheduled") // scheduled | done | cancelled
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId, datetime])
  @@index([staffId, datetime])
  @@map("appointment")
}

// Notifiche personalizzate (spec sez. 9). userId = destinatario (cliente o staff).
model Notification {
  id           String              @id @default(uuid())
  userId       String              @map("user_id")
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String // checkin_reminder | measurement_reminder | rating_request | pre_event | mini_plan | stall_coach_alert | no_checkin_coach_alert | ...
  payload      Json?
  channel      NotificationChannel @default(inapp)
  scheduledFor DateTime            @map("scheduled_for")
  sentAt       DateTime?           @map("sent_at")
  readAt       DateTime?           @map("read_at")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@index([userId, type, scheduledFor])
  @@map("notification")
}

// Token dei dispositivi per le notifiche push (FCM). FK-less (userId senza relazione).
model PushToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  String   @default("android") // android | ios | web
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("push_token")
}

// --- Motore a regole (milestone 5) ---

// Protocollo/regola: condizioni sui 5 segnali → azione (menu/tono/timing).
// Il motore usa SOLO regole approved (validazione a monte, spec 7.3).
model Protocol {
  id            String         @id @default(uuid())
  name          String
  type          String // menu_correction | threshold | library | ...
  definition    Json // { priority, conditions: [{field, op, value}], action: {menu, tone, timing, levelDelta, flag} }
  thresholds    Json?
  appliesTo     String?        @map("applies_to") // es. "senza condizioni cliniche"
  status        ProtocolStatus @default(pending)
  authorId      String?        @map("author_id")
  author        Staff?         @relation("ProtocolAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  validatedById String?        @map("validated_by_id")
  validatedBy   Staff?         @relation("ProtocolValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  validatedAt   DateTime?      @map("validated_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  decisions EngineDecision[]

  @@index([status])
  @@map("protocol")
}

// Decisione del motore: loggata e SPIEGABILE (snapshot input + regola applicata).
model EngineDecision {
  id               String    @id @default(uuid())
  clientId         String    @map("client_id")
  client           User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date             DateTime  @db.Date
  inputs           Json // snapshot dei 5 segnali al momento della decisione
  ruleId           String?   @map("rule_id")
  rule             Protocol? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  action           Json // {menu, tone, timing, level, note}
  flaggedForReview Boolean   @default(false) @map("flagged_for_review")
  flagReason       String?   @map("flag_reason")
  reviewedById     String?   @map("reviewed_by_id")
  reviewedAt       DateTime? @map("reviewed_at")
  reviewOutcome    String?   @map("review_outcome") // confirmed | corrected
  reviewNote       String?   @map("review_note")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([clientId, date])
  @@index([flaggedForReview, reviewedAt])
  @@map("engine_decision")
}

// --- Diete, ricette, menu (milestone 4) ---

// Dieta del catalogo: proposta da un nutrizionista, approvata dal capo.
model Diet {
  id           String     @id @default(uuid())
  name         String
  regime       String
  style        String
  mealsPerDay  Int        @map("meals_per_day")
  fasting      Boolean    @default(false) // digiuno intermittente 16:8 (pasti nella finestra 12-20)
  levels       Json? // es. [{level:1, kcal:1400}, {level:2, kcal:1600}]
  options      Json? // integratori, digiuno intermittente…
  authorId     String?    @map("author_id")
  author       Staff?     @relation("DietAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  status       DietStatus @default(draft)
  approvedById String?    @map("approved_by_id")
  approvedBy   Staff?     @relation("DietApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?  @map("approved_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  // Campi "prodotto" mostrati al cliente (schermo 16 "Stile che preferisci").
  clientName        String?  @map("client_name")
  clientDescription String?  @map("client_description")
  highlights        Json? // 3–5 "caratteristiche principali" mostrate al cliente
  seasonalTag       String?  @map("seasonal_tag")
  objective         String   @default("dimagrimento") // dimagrimento | mantenimento
  clientVisible     Boolean  @default(false) @map("client_visible")
  siteVisible       Boolean  @default(false) @map("site_visible") // mostrata sul SITO pubblico (indipendente da clientVisible dell'app)
  recommended       Boolean  @default(false) @map("recommended") // in evidenza nella sezione "Consigliati" dell'app

  dayTemplates DietDayTemplate[]
  menuDays     MenuDay[]

  @@index([status])
  @@index([regime, mealsPerDay, status])
  @@index([clientVisible])
  @@index([siteVisible])
  @@index([recommended])
  @@map("diet")
}

// Regole del motore attivate per un prodotto (dieta). rule_code dal catalogo (es. L5, L7, A2…).
// I comportamenti sono mappati su config_param; qui si sceglie quali attivare per prodotto (Fase F).
model ProductRule {
  id        String   @id @default(uuid())
  dietId    String   @map("diet_id")
  ruleCode  String   @map("rule_code")
  enabled   Boolean  @default(true)
  params    Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([dietId, ruleCode])
  @@index([dietId])
  @@map("product_rule")
}

// Coda "c'è un'altra regola?": proposta di una regola nuova, da approvare dal capo.
model RuleProposal {
  id         String   @id @default(uuid())
  dietId     String?  @map("diet_id") // opzionale: una proposta può essere generale (non legata a una dieta)
  title      String?  // titolo breve della regola proposta
  text       String
  proposedBy String?  @map("proposed_by")
  status     String   @default("pending") // pending | approved | rejected
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("rule_proposal")
}

// Regole "base" suggerite per tipo di nutrizione (letteratura). Il capo nutrizionista
// le vede col flag `suggested`, può modificarle, aggiungerne di nuove e applicarle a
// una dieta (→ ProductRule). `rules` = mappa { ruleCode: valore } dei parametri motore.
model RulePreset {
  id            String   @id @default(uuid())
  style         String // mediterranean | protein | low_carb | flexible | keto | dash | ...
  label         String
  description   String?
  regime        String? // omnivore | vegetarian | vegan | pescetarian | null = qualsiasi
  objective     String? // dimagrimento | mantenimento | null
  meals         String? // '3' | '5' | 'fasting' (digiuno intermittente 16:8) | null = 5 (storico)
  rules         Json     @default("{}") // { ruleCode: number|boolean }
  clinicalNotes String?  @map("clinical_notes") // regole cliniche non ancora parametrizzabili
  source        String? // fonte in letteratura
  suggested     Boolean  @default(true) // true = suggerita da noi (non ancora adottata dal capo)
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([style])
  @@map("rule_preset")
}

model Recipe {
  id             String   @id @default(uuid())
  name           String
  regime         String
  mealSlot       MealSlot @map("meal_slot")
  kcal           Int
  ingredients    Json // [{name, qty, unit}]
  cookingMethods Json?    @map("cooking_methods") // [{type: veloce|forno|meal_prep, steps: []}]
  tags           String[] @default([])
  macros         Json? // {protein_g, carbs_g, fat_g}
  active         Boolean  @default(true)
  // R8 sicurezza: allergeni (14 UE, codici) presenti nella ricetta. `reviewed` = il
  // nutrizionista ha CONFERMATO i tag (una ricetta non revisionata NON è considerata sicura).
  allergens         String[] @default([]) @map("allergens")
  allergensReviewed Boolean  @default(false) @map("allergens_reviewed")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  ratings RecipeRating[]

  @@index([regime, mealSlot, active])
  @@map("recipe")
}

// Struttura di una giornata per dieta+livello (rotazione su dayIndex).
model DietDayTemplate {
  id       String @id @default(uuid())
  dietId   String @map("diet_id")
  diet     Diet   @relation(fields: [dietId], references: [id], onDelete: Cascade)
  level    Int
  dayIndex Int    @map("day_index") // 1..N, il menu ruota su N giornate
  meals    Json // [{slot, recipeId}]

  @@unique([dietId, level, dayIndex])
  @@map("diet_day_template")
}

// Giornata di menu erogata alla cliente (2 giorni alla volta).
model MenuDay {
  id           String   @id @default(uuid())
  clientId     String   @map("client_id")
  client       User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  dietId       String   @map("diet_id")
  diet         Diet     @relation(fields: [dietId], references: [id], onDelete: Restrict)
  level        Int      @default(1)
  meals        Json // snapshot [{slot, recipeId, name, kcal}]
  status       String   @default("planned")
  visibleFrom  DateTime @map("visible_from") @db.Date
  sourceRuleId String?  @map("source_rule_id") // valorizzato dal motore (M5)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([clientId, date])
  @@index([clientId, date])
  @@map("menu_day")
}

// Segnale "Gusto": valutazione di una ricetta consumata.
model RecipeRating {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recipeId String   @map("recipe_id")
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  stars    Int // 1–5
  tags     String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, recipeId, date])
  @@index([recipeId])
  @@map("recipe_rating")
}

// Lista spesa per un intervallo di menu (con spunte persistenti).
model ShoppingList {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dateFrom DateTime @map("date_from") @db.Date
  dateTo   DateTime @map("date_to") @db.Date
  items    Json // [{name, qty, unit, checked}]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, dateFrom, dateTo])
  @@map("shopping_list")
}

// --- Segnali (milestone 3): il carburante del motore ---

// Segnale "Corpo": misure inserite ~ogni 2 giorni. Una per giorno.
model Measurement {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  weightKg Float    @map("weight_kg")
  waistCm  Float?   @map("waist_cm")
  hipsCm   Float?   @map("hips_cm")
  thighsCm Float?   @map("thighs_cm")
  // Correzione stesso giorno (una sola volta): snapshot della misura PRECEDENTE ("sostituita").
  // I valori correnti restano quelli buoni → grafici e report usano i correnti e NON conteggiano
  // la sostituita. replacedSnapshot != null ⇒ la misura di quel giorno è già stata corretta.
  replacedSnapshot Json?   @map("replaced_snapshot")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, date])
  @@index([clientId, date])
  @@map("measurement")
}

// Segnale "Testa": check-in giornaliero (umore obbligatorio, il resto opzionale 1–5).
model DailyCheckin {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  mood     Mood
  energy   Int?
  hunger   Int?
  stress   Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, date])
  @@index([clientId, date])
  @@map("daily_checkin")
}

model WaterLog {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  glasses  Int
  goal     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, date])
  @@map("water_log")
}

model StepLog {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  steps    Int
  goal     Int
  source   String?  // manual | healthkit | google_fit (futuro)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, date])
  @@map("step_log")
}

// Log delle note dello staff sul cliente: ogni salvataggio è una voce
// (testo, autore, data/ora). Non è una nota clinica riservata: è visibile a
// chi gestisce il cliente (coach ecc.).
model ClientNote {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  client    User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  body      String
  authorId  String?  @map("author_id")
  author    Staff?   @relation("ClientNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId, createdAt])
  @@map("client_note")
}

// Traguardi raggiunti (celebrazioni): prima misura, -1/-3/-5 kg, metà strada, obiettivo.
model Milestone {
  id         String   @id @default(uuid())
  clientId   String   @map("client_id")
  client     User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type       String // first_measurement | lost_1kg | lost_3kg | lost_5kg | halfway | goal_reached
  label      String
  achievedAt DateTime @default(now()) @map("achieved_at")

  @@unique([clientId, type])
  @@index([clientId])
  @@map("milestone")
}

// Refresh token (rotazione): salvato solo l'hash, mai il token in chiaro.
model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_token")
}

// Token monouso per verifica email e reset password (salvato hashato).
model ActionToken {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActionTokenType
  tokenHash String          @unique @map("token_hash")
  email     String?         // email di destinazione (per il cambio email)
  expiresAt DateTime        @map("expires_at")
  usedAt    DateTime?       @map("used_at")
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([userId, type])
  @@map("action_token")
}

// Soglie e parametri del motore, configurabili a runtime (mai hardcodati).
// Valori iniziali: Appendice A della specifica.
model ConfigParam {
  key         String          @id
  value       String
  type        ConfigParamType @default(number)
  description String?
  updatedById String?         @map("updated_by_id")
  updatedBy   User?           @relation("ConfigUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("config_param")
}

// Provvigione accantonata: creata quando al pagamento manca lo staff assegnato
// (es. cliente che paga la visita prima di avere il nutrizionista). Viene pagata
// quando lo staff viene assegnato dal backoffice (o annullata se non dovuta).
model PendingCommission {
  id              String    @id @default(uuid())
  paymentId       String    @map("payment_id")
  clientId        String    @map("client_id")
  role            String // coach | manager_coach | nutritionist | head_nutritionist
  amountCents     Int       @map("amount_cents")
  status          String    @default("pending") // pending | paid | cancelled
  resolvedStaffId String?   @map("resolved_staff_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  resolvedAt      DateTime? @map("resolved_at")

  @@index([clientId, status])
  @@map("pending_commission")
}

// Buono sconto: percentuale o importo fisso, con tetto di utilizzi totali e per
// cliente. Il cliente lo inserisce al momento dell'acquisto.
model DiscountCode {
  id           String    @id @default(uuid())
  code         String    @unique // codice inserito dal cliente (maiuscolo)
  type         String // percent | fixed
  value        Int // percent (es. 10) oppure importo in centesimi
  // Codice PERSONALE (handoff punto 3 "Codici sconto personali"): se valorizzato,
  // solo questa cliente può usarlo (es. GIULIA-FOUND inviato al giorno 6 della prova).
  clientId     String?   @map("client_id")
  // Opzione B (decisione 17/07): target esatti PER PIANO — { planId: prezzoTargetCents }.
  // Se valorizzato, il codice vale solo per quei piani e porta il piano al prezzo target
  // (es. 3 mesi 29900→24900, 1 mese 13000→9900), sconto calcolato sul prezzo pieno.
  planTargets  Json?     @map("plan_targets")
  maxTotalUses Int?      @map("max_total_uses") // null = illimitato
  maxPerClient Int       @default(1) @map("max_per_client")
  usedCount    Int       @default(0) @map("used_count")
  active       Boolean   @default(true)
  expiresAt    DateTime? @map("expires_at")
  createdById  String?   @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  redemptions DiscountRedemption[]

  @@index([clientId])
  @@map("discount_code")
}

model DiscountRedemption {
  id          String       @id @default(uuid())
  codeId      String       @map("code_id")
  code        DiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  clientId    String       @map("client_id")
  paymentId   String?      @map("payment_id")
  amountCents Int          @map("amount_cents") // sconto applicato
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([codeId, clientId])
  @@map("discount_redemption")
}

// Modello email modificabile dall'admin. subject/bodyHtml usano segnaposto {{var}}.
// Se manca o è disattivato, si usa il testo predefinito (i18n).
model EmailTemplate {
  key         String   @id // es. payment_receipt, password_reset, ...
  name        String
  subject     String
  bodyHtml    String   @map("body_html")
  active      Boolean  @default(true)
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_template")
}

/** Template HTML dei PDF inviati ai clienti (ricevuta, report mensile), modificabili da admin. */
model PdfTemplate {
  key         String   @id // 'receipt', 'monthly_report'
  name        String
  html        String
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("pdf_template")
}

// Log di ogni email tentata (per verificare gli invii).
model EmailLog {
  id          String   @id @default(uuid())
  to          String
  templateKey String?  @map("template_key")
  subject     String
  bodyHtml    String?  @map("body_html")
  status      String // sent | failed | skipped
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("email_log")
}

// Matrice permessi del backoffice: ruolo × sezione → vede / gestisce.
// I default arrivano dal seed (specifica sez. 4); l'admin li modifica a runtime.
// Ruoli personalizzati: etichetta + colore + ruolo di sistema di base (da cui
// ereditano i permessi reali). Aggiunti/rimossi dall'admin dal backoffice.
model CustomRole {
  key         String   @id
  label       String
  color       String?
  baseRole    Role     @map("base_role")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]

  @@map("custom_role")
}

model RolePagePermission {
  role        String // ruolo di sistema o chiave di un ruolo personalizzato
  pageKey     String   @map("page_key")
  canView     Boolean  @default(false) @map("can_view")
  canManage   Boolean  @default(false) @map("can_manage")
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@id([role, pageKey])
  @@map("role_page_permission")
}

// Audit log: ogni accesso/azione su dati sanitari e ogni decisione del motore.
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String // es. "user.login", "config_param.update", "health_data.read"
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

// Testimonianze del sito pubblico (gestite dal backoffice, approvate dal marketing).
// Endpoint pubblico: GET /public/testimonials (solo published). Vedi TestimonialsModule.
model Testimonial {
  id        String   @id @default(uuid())
  name      String
  age       Int?
  text      String
  photo     String?
  locale    String   @default("it")
  published Boolean  @default(true)
  order     Int      @default(0)
  source    String? // provenienza, es. "marketing", "cliente"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([published, order])
  @@map("testimonial")
}

// ============================================================================
// MOTORE INTELLIGENTE — Fase B (R8–R12): scheletro modelli (E0, senza logica).
// Approvati dal socio (Metabole_Motore_R8_R12_Decisioni.md). Additivi, isolati
// per prodotto. La logica dell'agente arriverà nelle fasi E1–E5.
// ============================================================================

// R4/R8 — Gruppi di equivalenza per le sostituzioni (safety-critical).
// Di proprietà del nutrizionista (workflow draft→approved, versionato).
// productId null = gruppo globale; le sostituzioni restano comunque dentro il pool del prodotto.
model EquivalenceGroup {
  id        String   @id @default(uuid())
  name      String
  productId String?  @map("product_id") // Diet.id; null = globale
  members   Json     @default("[]") // alimenti/ingredienti/recipeId equivalenti
  status    String   @default("draft") // draft | approved
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@index([status])
  @@map("equivalence_group")
}

// R8 — Base personalizzata del cliente (copia filtrata del pool del prodotto), isolata per client_id.
model ClientMenuPool {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  dietId    String   @map("diet_id")
  version   Int      @default(1)
  recipeIds String[] @default([]) @map("recipe_ids") // ricette ammesse dopo esclusioni/sostituzioni
  excluded  Json?    // audit: cosa rimosso/sostituito e perché
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, dietId, version])
  @@index([clientId])
  @@map("client_menu_pool")
}

// R10/R11 — Ciclo bigiornaliero attivo del cliente + stato contestuale (D4: lo stato vive qui).
model ClientCycle {
  id            String   @id @default(uuid())
  clientId      String   @map("client_id")
  dietId        String   @map("diet_id")
  cycleStart    DateTime @map("cycle_start") @db.Date
  cycleEnd      DateTime @map("cycle_end") @db.Date
  dayTemplateId String?  @map("day_template_id") // menu erogato nel ciclo
  cookingG1     String?  @map("cooking_g1") // metodo cottura giorno 1
  cookingG2     String?  @map("cooking_g2") // metodo cottura giorno 2 (kcal invariate)
  state         String   @default("normale") // normale|conforto|rientro|pre_evento|post_evento|plateau
  status        String   @default("active") // active|closed|paused
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([clientId, cycleEnd])
  @@map("client_cycle")
}

// R9 — Certificato di unicità della personalizzazione (seme + firma HMAC/hash-chain).
model PersonalizationCertificate {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  dietId    String?  @map("diet_id")
  seed      String // seme deterministico derivato da client_id
  signature String // hash(cliente, menu, ricette, stato, versione)
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([clientId, version])
  @@index([clientId])
  @@map("personalization_certificate")
}

// ============================================================================
// MARKETING — Agente Publisher: log/coda dei post social. Ogni post passa dal
// Giudice (compliance) prima della pubblicazione. Pubblicazione social ed export
// Canva sono stub in attesa delle credenziali delle piattaforme.
// ============================================================================
model SocialPost {
  id           String    @id @default(uuid())
  collectionId String?   @map("collection_id") // id collezione dal catalogo vignette (es. persona.maria_matrimonio)
  channel      String // instagram | facebook | ...
  caption      String
  hashtags     String[]  @default([])
  imageRef     String?   @map("image_ref") // design_id Canva o path PNG
  imageSource  String?   @map("image_source") // canva | png_locale
  status       String    @default("draft") // draft|judged|approved|scheduled|published|failed|rejected
  judgePass    Boolean?  @map("judge_pass")
  judgeIssues  Json?     @map("judge_issues") // string[] dei problemi rilevati dal Giudice
  scheduledAt  DateTime? @map("scheduled_at")
  publishedAt  DateTime? @map("published_at")
  externalId   String?   @map("external_id") // id del post sulla piattaforma (dopo la pubblicazione)
  error        String?
  createdById  String?   @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([channel, scheduledAt])
  @@map("social_post")
}

// Casella di posta @metabole.eu dell'utente (MVP webmail, MVP: solo staff).
// La password della casella è cifrata a riposo (AES-256-GCM, chiave FILE_ENCRYPTION_KEY).
// I parametri server (IMAP/SMTP mail.metabole.eu) sono uguali per tutti → in env/config.
model MailAccount {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email       String // indirizzo completo della casella (es. mario@metabole.eu)
  encPassword String   @map("enc_password") // password casella cifrata (base64)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("mail_account")
}

/// Campagna marketing: segmento (filtri usati), destinatari CONGELATI al momento
/// dell'invio, e la mail effettivamente inviata (snapshot subject+html).
model MarketingCampaign {
  id             String   @id @default(uuid())
  title          String
  templateKey    String   @map("template_key")
  subject        String
  bodyHtml       String   @map("body_html")
  segment        Json     @default("{}") // criteri di filtro usati
  recipients     Json     @default("[]") // [{email, name, recordId}] congelati all'invio
  recipientCount Int      @default(0) @map("recipient_count")
  sentCount      Int      @default(0) @map("sent_count")
  failedCount    Int      @default(0) @map("failed_count")
  status         String   @default("sent") // scheduled | sending | sent | canceled (righe storiche: sent)
  // Invio programmato + throttle a lotti (invia N e-mail, poi pausa di M minuti).
  scheduledFor   DateTime? @map("scheduled_for") // quando far partire (null = subito)
  batchSize      Int      @default(0) @map("batch_size") // e-mail per lotto (0 = tutte insieme)
  pauseMinutes   Int      @default(0) @map("pause_minutes") // pausa tra un lotto e il successivo
  cursor         Int      @default(0) // destinatari già processati (indice nell'array congelato)
  nextBatchAt    DateTime? @map("next_batch_at") // quando è dovuto il prossimo lotto (usato dal ticker)
  // Azione POST-INVIO sui destinatari effettivamente inviati: aggiungi etichetta
  // e/o cambia stato pipeline (entrambe facoltative, applicate per lotto).
  postTag        String?  @map("post_tag")
  postStage      String?  @map("post_stage")
  createdById    String?  @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([status, nextBatchAt])
  @@map("marketing_campaign")
}

/// Opt-out marketing per email (leads + clienti): alimentato dal webhook Brevo
/// su disiscrizione/spam/bounce. Le campagne escludono queste email.
model MarketingOptOut {
  email     String   @id
  reason    String?
  source    String   @default("brevo")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("marketing_opt_out")
}

/// Automazione email del ciclo di vita: impostazioni globali (riga singola
/// "singleton"). enabled = interruttore master; triggers = mappa chiave→bool
/// per accendere/spegnere ogni innesco; lastRunAt = ultima esecuzione dello scan.
model LifecycleSettings {
  id          String    @id @default("singleton")
  enabled     Boolean   @default(false)
  triggers    Json?
  lastRunAt   DateTime? @map("last_run_at")
  updatedById String?   @map("updated_by_id")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("lifecycle_settings")
}

/// Log/dedup degli invii ciclo di vita: garantisce che un innesco parta una sola
/// volta per utente (dedupeKey = chiave, o chiave:anno per gli eventi ricorrenti).
model LifecycleEmail {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  templateKey String   @map("template_key")
  dedupeKey   String   @map("dedupe_key")
  sentAt      DateTime @default(now()) @map("sent_at")

  @@unique([userId, dedupeKey])
  @@index([templateKey])
  @@index([sentAt])
  @@map("lifecycle_email")
}


// Richiesta di PAUSA/congelamento dell'abbonamento (modalità vacanza).
// ≤ FREEZE_AUTO_MAX_DAYS giorni: auto-approvata (la scadenza slitta subito).
// Oltre: resta "pending" finché coach o nutrizionista assegnato non approva.
model PauseRequest {
  id               String    @id @default(uuid())
  clientId         String    @map("client_id")
  client           User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  startDate        DateTime  @map("start_date") @db.Date
  endDate          DateTime  @map("end_date") @db.Date
  days             Int
  status           String    @default("pending") // pending | auto_approved | approved | rejected
  eventId          String?   @map("event_id") // Event pausa creato all'approvazione
  decidedByStaffId String?   @map("decided_by_staff_id")
  decidedAt        DateTime? @map("decided_at")
  staffNote        String?   @map("staff_note")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([status])
  @@map("pause_request")
}

// ---------- Sistema Agenti AI (Metabole_Agenti_AI_Spec_Sviluppo.md) ----------

// Registro degli agenti: la sezione backoffice "Agenti" fa CRUD su questa tabella.
// I nomi dei modelli NON sono hardcodati: default in config_param (agent_default_model…).
model Agent {
  id                String    @id @default(uuid())
  key               String    @unique // slug (gaia, giudice, redattore_blog…)
  name              String
  type              String // conversational|generative|judge|rag|planner|analyst|writer|orchestrator|tts|deterministic
  department        String // app|marketing|communication|crm|system
  task              String // "cosa fa"
  rule              String // "regola" (vincolo sempre valido)
  engine            String // claude-haiku-4-5|claude-sonnet-5|claude-opus-4-8|elevenlabs|none
  systemPrompt      String?   @map("system_prompt") // prompt di sistema versionato
  tools             Json      @default("[]") // tool/endpoint che può usare
  enabled           Boolean   @default(true)
  humanInLoop       Boolean   @default(false) @map("human_in_loop")
  monthlyBudgetCents Int      @default(0) @map("monthly_budget_cents") // 0 = nessun tetto
  archivedAt        DateTime? @map("archived_at") // soft delete
  createdById       String?   @map("created_by_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  runs AgentRun[]

  @@index([department])
  @@index([enabled])
  @@map("agent")
}

// Esecuzioni degli agenti: token, costi, verdetti (per dashboard costi e audit).
model AgentRun {
  id           String    @id @default(uuid())
  agentId      String    @map("agent_id")
  agent        Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  startedAt    DateTime  @default(now()) @map("started_at")
  finishedAt   DateTime? @map("finished_at")
  status       String    @default("queued") // queued|running|done|error|blocked
  inputRef     String?   @map("input_ref")
  outputRef    String?   @map("output_ref")
  model        String?
  inputTokens  Int       @default(0) @map("input_tokens")
  outputTokens Int       @default(0) @map("output_tokens")
  costCents    Int       @default(0) @map("cost_cents")
  verdict      String? // per il Giudice: approva|rivedi|blocca
  approvedById String?   @map("approved_by_id")
  error        String?

  logs AgentLog[]

  @@index([agentId, startedAt])
  @@index([status])
  @@map("agent_run")
}

// Audit append-only delle esecuzioni (obbligatorio per il Giudice e le decisioni sui contenuti).
model AgentLog {
  id         String   @id @default(uuid())
  agentRunId String   @map("agent_run_id")
  run        AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  ts         DateTime @default(now())
  level      String   @default("info") // info|warn|error|decision
  message    String
  payload    Json?

  @@index([agentRunId, ts])
  @@map("agent_log")
}

// ---------- Task coach (handoff Prezzi/Prova, punto 5: "la coach deve vedere cosa fare e quando") ----------

// Task operativi generati in automatico dal cron sui momenti chiave della prova e
// dei piani (G0 misure, G1 benvenuto, G4 aderenza, G7 chiusura, fine piano, +7 ultima
// chiamata). Stato gestito dalla coach: da fare / fatto / saltato.
model CoachTask {
  id          String    @id @default(uuid())
  clientId    String    @map("client_id")
  client      User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  kind        String // trial_g0_measures | trial_g1_welcome | trial_g4_adherence | trial_g6_code | trial_g7_closing | plan_end_report | trial_post7_lastcall
  refId       String    @default("") @map("ref_id") // es. subscription.id (per l'unicità sui piani ripetuti)
  title       String
  description String?
  dueDate     DateTime  @map("due_date") @db.Date
  status      String    @default("todo") // todo | done | skipped
  doneById    String?   @map("done_by_id")
  doneAt      DateTime? @map("done_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([clientId, kind, refId])
  @@index([status, dueDate])
  @@index([clientId])
  @@map("coach_task")
}

// ---------- Report di fine piano (handoff Prezzi/Prova, punto 4) ----------

// Snapshot del report A→B generato in automatico a OGNI fine piano (prova inclusa).
// Consegna IN APP (dati sanitari: mai allegato a email/WhatsApp). I dati sono
// congelati in `data` al momento della generazione: il report resta leggibile
// anche dopo il purge del profilo personalizzato.
model ClientReport {
  id             String    @id @default(uuid())
  clientId       String    @map("client_id")
  client         User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscriptionId String    @map("subscription_id")
  // Un report FINALE per piano ('final') + eventuali report MENSILI ('m1','m2',…)
  // per i piani più lunghi di un mese: stesso impianto, cadenza diversa.
  periodKey      String    @default("final") @map("period_key")
  kind           String // trial | plan | monthly
  periodStart    DateTime  @map("period_start") @db.Date
  periodEnd      DateTime  @map("period_end") @db.Date
  data           Json
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@unique([subscriptionId, periodKey])
  @@index([clientId, createdAt])
  @@map("client_report")
}
