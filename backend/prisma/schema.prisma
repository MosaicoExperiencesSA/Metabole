// Metabole — schema Prisma
// Milestone 1 (Fondamenta): utenti, parametri motore, audit log.
// Riferimento: docs Metabole_Specifica_Backend_Sviluppatore.md (sez. 5, 13, Appendice A)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (runtime)
  directUrl = env("DIRECT_DATABASE_URL") // diretta (solo migrazioni/seed)
}

// --- Enum ---

enum Role {
  client
  coach
  nutritionist
  head_nutritionist
  sales
  admin
}

enum UserStatus {
  active
  suspended
  deleted
}

enum ConfigParamType {
  number
  string
  boolean
  json
}

enum ActionTokenType {
  email_verification
  password_reset
  email_change
}

enum Sex {
  female
  male
}

enum Regime {
  omnivore
  vegetarian
  vegan
}

enum DietStyle {
  mediterranean
  protein
  low_carb
  flexible
}

enum PathType {
  classic3
  five
  supplements
  intermittent_fasting
}

enum CoachStyle {
  daily
  when_needed
  on_request
}

enum Character {
  follows
  needs_push
  perseveres
  quits
}

enum ObjectiveStatus {
  proposed
  confirmed
  achieved
  revised
}

enum EscalationSource {
  screening
  coach
  engine
}

enum EscalationStatus {
  open
  in_progress
  resolved
}

enum Mood {
  great
  good
  ok
  hard
  stressed
}

enum DietStatus {
  draft
  in_review
  approved
  rejected
}

enum ProtocolStatus {
  pending
  approved
  rejected
}

enum EventType {
  wedding
  baptism
  dinner
  monthly_cheat
  vacation
  other
}

enum EventMode {
  single_event
  pause_period
}

enum NotificationChannel {
  inapp
  email
  push
}

enum VisitType {
  in_person
  televisit
}

enum VisitStatus {
  scheduled
  done
  cancelled
}

enum DocumentType {
  blood_test
  photo
  other
}

enum DocumentStatus {
  pending
  reviewed
}

enum ChatCounterpart {
  ai
  coach
  nutritionist
}

enum PaymentMethod {
  manual // acquisto inserito a mano dall'operatore
  bank_transfer
  card
}

enum PaymentStatus {
  pending
  receipt_uploaded
  approved
  rejected
}

enum SubscriptionStatus {
  pending
  active
  cancelled
  expired
}

enum OrderStatus {
  pending
  paid
  cancelled
}

enum LedgerType {
  income
  expense
}

enum MealSlot {
  breakfast
  morning_snack
  lunch
  afternoon_snack
  dinner
}

// --- Modelli ---

model User {
  id              String     @id @default(uuid())
  email           String     @unique
  secondaryEmail  String?    @unique @map("secondary_email") // email alternativa per il login (verificata); notifiche/ricevute vanno sempre alla principale `email`
  passwordHash    String     @map("password_hash")
  role            Role       @default(client)
  customRoleKey   String?    @map("custom_role_key") // ruolo personalizzato (etichetta+menu); il ruolo di sistema resta in `role`
  customRole      CustomRole? @relation(fields: [customRoleKey], references: [key], onDelete: SetNull)
  locale          String     @default("it")
  status          UserStatus @default(active)
  emailVerifiedAt DateTime?  @map("email_verified_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")
  prefs           Json?      @map("prefs") // preferenze UI (es. scorciatoie dashboard)
  firstName       String?    @map("first_name")
  lastName        String?    @map("last_name")
  title           String?    // titolo/qualifica mostrata nel backoffice (es. "Coach", "Dr.ssa")
  theme           String     @default("light") // tema grafico backoffice: light | dark | taupe | white
  addressLine     String?    @map("address_line") // via e numero civico
  postalCode      String?    @map("postal_code")  // CAP
  city            String?
  province        String?
  country         String?    // paese dell'indirizzo (es. Italia, Svizzera)
  phone           String?

  auditLogs       AuditLog[]
  configChanges   ConfigParam[] @relation("ConfigUpdatedBy")
  refreshTokens   RefreshToken[]
  actionTokens    ActionToken[]
  staff           Staff?
  clientProfile   ClientProfile?
  objectives      Objective[]
  escalations     Escalation[]
  measurements    Measurement[]
  checkins        DailyCheckin[]
  waterLogs       WaterLog[]
  stepLogs        StepLog[]
  milestones      Milestone[]
  menuDays        MenuDay[]
  recipeRatings   RecipeRating[]
  shoppingLists   ShoppingList[]
  engineDecisions EngineDecision[]
  events          Event[]
  notifications   Notification[]
  visits          Visit[]
  documents       Document[]
  clinicalNotes   ClinicalNote[]
  chatThreads     ChatThread[]
  subscriptions   Subscription[]
  payments        Payment[]
  orders          Order[]
  crmRecord       CrmRecord?
  staffNotes      ClientNote[]

  @@index([role])
  @@map("user")
}

// Scheda dello staff (coach, nutrizionisti, capo, commerciali).
model Staff {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName         String   @map("display_name")
  specialties         String[] @default([])
  bio                 String?
  refCode             String?  @unique @map("ref_code") // codice di riferimento della coach
  iban                String?  // IBAN salvato per i prelievi provvigioni
  headNutritionistId  String?  @map("head_nutritionist_id")
  headNutritionist    Staff?   @relation("NutritionistTeam", fields: [headNutritionistId], references: [id], onDelete: SetNull)
  teamMembers         Staff[]  @relation("NutritionistTeam")
  // Responsabile diretto (un livello sopra) per le provvigioni di catena:
  // per una coach è la manager coach, per un nutrizionista il capo nutrizionista.
  managerId           String?  @map("manager_id")
  manager             Staff?   @relation("StaffManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports             Staff[]  @relation("StaffManager")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  clientsAsCoach        ClientProfile[] @relation("AssignedCoach")
  clientsAsNutritionist ClientProfile[] @relation("AssignedNutritionist")
  escalations           Escalation[]    @relation("EscalationAssignee")
  authoredDiets         Diet[]          @relation("DietAuthor")
  approvedDiets         Diet[]          @relation("DietApprover")
  authoredProtocols     Protocol[]      @relation("ProtocolAuthor")
  validatedProtocols    Protocol[]      @relation("ProtocolValidator")
  visits                Visit[]         @relation("VisitNutritionist")
  reviewedDocuments     Document[]      @relation("DocumentReviewer")
  clinicalNotes         ClinicalNote[]  @relation("NoteAuthor")
  approvedPayments      Payment[]       @relation("PaymentApprover")
  ownedLeads            CrmRecord[]     @relation("LeadOwner")
  coachLeads            CrmRecord[]     @relation("LeadCoach")
  assignedLeads         CrmRecord[]     @relation("LeadAssigner")
  compensations         StaffCompensation[] @relation("CompensationStaff")
  authoredClientNotes   ClientNote[]        @relation("ClientNoteAuthor")
  withdrawals           CommissionWithdrawal[] @relation("StaffWithdrawals")

  @@map("staff")
}

/** Richiesta di prelievo delle provvigioni maturate (portafoglio staff). */
model CommissionWithdrawal {
  id           String    @id @default(uuid())
  staffId      String    @map("staff_id")
  staff        Staff     @relation("StaffWithdrawals", fields: [staffId], references: [id], onDelete: Cascade)
  amountCents  Int       @map("amount_cents")
  iban         String
  status       String    @default("requested") // requested | paid | rejected
  receiptData  Bytes?    @map("receipt_data") // ricevuta/fattura caricata (cifrata)
  receiptMime  String?   @map("receipt_mime")
  receiptName  String?   @map("receipt_name")
  note         String?   // motivo del rifiuto o nota dell'operatore
  requestedAt  DateTime  @default(now()) @map("requested_at")
  paidAt       DateTime? @map("paid_at")
  approvedById String?   @map("approved_by_id")

  @@index([staffId, status])
  @@map("commission_withdrawal")
}

// Profilo della cliente: compilato dal questionario di onboarding (15 pagine).
model ClientProfile {
  id                     String     @id @default(uuid())
  userId                 String     @unique @map("user_id")
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                   String?
  age                    Int?
  sex                    Sex?
  heightCm               Int?       @map("height_cm")
  startWeightKg          Float?     @map("start_weight_kg")
  startWaistCm           Float?     @map("start_waist_cm")
  startHipsCm            Float?     @map("start_hips_cm")
  regime                 Regime?
  dietStyle              DietStyle? @map("diet_style")
  mealsPerDay            Int?       @map("meals_per_day")
  pathType               PathType?  @map("path_type")
  coachStyle             CoachStyle? @map("coach_style")
  character              Character?
  intolerances           String[]   @default([])
  dislikedFoods          String[]   @default([]) @map("disliked_foods")
  lifestyle              Json?      // lavoro, tempo per cucinare, pranzo feriali (segnale "Vita")
  themeColor             String?    @map("theme_color")
  planStartDate          DateTime?  @map("plan_start_date")
  assignedCoachId        String?    @map("assigned_coach_id")
  assignedCoach          Staff?     @relation("AssignedCoach", fields: [assignedCoachId], references: [id], onDelete: SetNull)
  assignedNutritionistId String?    @map("assigned_nutritionist_id")
  assignedNutritionist   Staff?     @relation("AssignedNutritionist", fields: [assignedNutritionistId], references: [id], onDelete: SetNull)
  consents               Json?      // versioni dei consensi accettati
  notificationPrefs      Json?      @map("notification_prefs") // opt-out per tipo + email opzionale
  screeningFlag          Boolean    @default(false) @map("screening_flag")
  onboardingAnswers      Json?      @map("onboarding_answers") // snapshot grezzo delle risposte
  onboardingCompletedAt  DateTime?  @map("onboarding_completed_at")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  @@index([assignedCoachId])
  @@index([assignedNutritionistId])
  @@map("client_profile")
}

// Obiettivo della cliente: creato nel questionario, confermato da coach+nutrizionista,
// riconfermato dopo ogni visita (history).
model Objective {
  id                       String          @id @default(uuid())
  clientId                 String          @map("client_id")
  client                   User            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  targetWeightKg           Float?          @map("target_weight_kg")
  targetWaistCm            Float?          @map("target_waist_cm")
  targetHipsCm             Float?          @map("target_hips_cm")
  targetDate               DateTime?       @map("target_date")
  status                   ObjectiveStatus @default(proposed)
  confirmedByCoachAt       DateTime?       @map("confirmed_by_coach_at")
  confirmedByNutritionistAt DateTime?      @map("confirmed_by_nutritionist_at")
  history                  Json?           // riconferme/revisioni dopo ogni visita
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")

  @@index([clientId])
  @@map("objective")
}

// Presa in carico dei casi da supervisionare (screening, alert coach, motore).
model Escalation {
  id           String           @id @default(uuid())
  clientId     String           @map("client_id")
  client       User             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reason       String
  source       EscalationSource
  assignedToId String?          @map("assigned_to_id")
  assignedTo   Staff?           @relation("EscalationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  status       EscalationStatus @default(open)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([status])
  @@map("escalation")
}

// --- CRM, commercio, contabilità (milestone 9) ---

// Piano di abbonamento (prezzi in CENTESIMI: niente virgole mobili sui soldi).
model Plan {
  id          String   @id @default(uuid())
  name        String
  priceCents  Int      @map("price_cents")
  period      String // es. 3m | 6m | 12m
  mealsPerDay Int?     @map("meals_per_day")
  features    String[] @default([])
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plan")
}

model Subscription {
  id        String             @id @default(uuid())
  clientId  String             @map("client_id")
  client    User               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  planId    String             @map("plan_id")
  plan      Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  status    SubscriptionStatus @default(pending)
  startDate DateTime?          @map("start_date")
  endDate   DateTime?          @map("end_date")
  pspRef    String?            @map("psp_ref")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  payments Payment[]

  @@index([clientId, status])
  @@map("subscription")
}

// Pagamento con flusso bonifico: pending → receipt_uploaded → approved|rejected.
// L'abbonamento (e menu/provvigioni) si attiva SOLO all'approvazione dell'operatore.
model Payment {
  id             String        @id @default(uuid())
  clientId       String        @map("client_id")
  client         User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscriptionId String?       @map("subscription_id")
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  orderId        String?       @unique @map("order_id")
  order          Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  amountCents    Int           @map("amount_cents")
  description    String
  method         PaymentMethod @default(bank_transfer)
  status         PaymentStatus @default(pending)
  receiptData    Bytes?        @map("receipt_data") // contabile cifrata AES-256-GCM
  receiptMime    String?       @map("receipt_mime")
  receiptName    String?       @map("receipt_name")
  approvedById   String?       @map("approved_by_id")
  approvedBy     Staff?        @relation("PaymentApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt     DateTime?     @map("approved_at")
  rejectReason   String?       @map("reject_reason")
  pspRef         String?       @map("psp_ref")
  discountCodeId String?       @map("discount_code_id")
  discountCents  Int?          @map("discount_cents")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([clientId, createdAt])
  @@map("payment")
}

// Integratori (spec): catalogo minimo.
model Product {
  id          String   @id @default(uuid())
  name        String
  priceCents  Int      @map("price_cents")
  description String?
  active      Boolean  @default(true)
  // A quale team vanno le provvigioni di questo prodotto: both | coaching | nutrition
  commissionTeam String @default("both") @map("commission_team")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("product")
}

model Order {
  id         String      @id @default(uuid())
  clientId   String      @map("client_id")
  client     User        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status     OrderStatus @default(pending)
  totalCents Int         @map("total_cents")
  items      Json // [{productId, name, priceCents, qty}]
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  payment Payment?

  @@index([clientId])
  @@map("order")
}

// CRM: ogni transizione di stage salva data + responsabile (spec sez. 8).
model CrmRecord {
  id         String   @id @default(uuid())
  clientId   String?  @unique @map("client_id")
  client     User?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  email      String?
  name       String?
  stage      String   @default("lead_in") // chiave di pipeline_stage (gestita da admin)
  stageDates Json     @default("{}") @map("stage_dates") // {stage: {at, byUserId}}
  ownerId    String?  @map("owner_id")
  owner      Staff?   @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  valueCents Int?     @map("value_cents")
  // Assegnazione alla coach con accettazione (2 giorni), oppure diretta via ref code.
  assignedCoachId  String?   @map("assigned_coach_id")
  assignedCoach    Staff?    @relation("LeadCoach", fields: [assignedCoachId], references: [id], onDelete: SetNull)
  assignmentStatus String?   @map("assignment_status") // pending | accepted
  assignedAt       DateTime? @map("assigned_at")
  assignedById     String?   @map("assigned_by_id")
  assignedBy       Staff?    @relation("LeadAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  reminders  CrmReminder[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([stage])
  @@index([assignedCoachId, assignmentStatus])
  @@map("crm_record")
}

// Calendario CRM: promemoria/appuntamenti, opzionalmente legati a un lead/cliente.
model CrmReminder {
  id          String     @id @default(uuid())
  crmRecordId String?    @map("crm_record_id")
  crmRecord   CrmRecord? @relation(fields: [crmRecordId], references: [id], onDelete: SetNull)
  title       String
  dueAt       DateTime   @map("due_at")
  note        String?
  done        Boolean    @default(false)
  createdById String?    @map("created_by_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([dueAt])
  @@index([crmRecordId])
  @@map("crm_reminder")
}

// Stati della pipeline commerciale/clienti, gestibili dall'admin (condivisi).
// La KEY è stabile (usata dall'automazione: lead_in alla registrazione, paid
// all'approvazione pagamento); label/color/order/visibilità sono personalizzabili.
model PipelineStage {
  key       String   @id
  label     String
  color     String?
  order     Int      @default(0)
  isSystem  Boolean  @default(false) @map("is_system") // key referenziata dall'automazione: non eliminabile
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([order])
  @@map("pipeline_stage")
}

// Contabilità: eventi economici automatici, niente doppio inserimento.
model LedgerEntry {
  id        String     @id @default(uuid())
  type      LedgerType
  amountCents Int      @map("amount_cents")
  category  String // subscription | order | sales_commission | visit_compensation | ...
  date      DateTime   @default(now())
  ref       String? // payment/visit id
  clientId  String?    @map("client_id")
  staffId   String?    @map("staff_id")
  note      String?

  @@index([type, date])
  @@index([category, date])
  @@map("ledger_entry")
}

// Compensi/provvigioni dello staff, aggregati per periodo (YYYY-MM).
model StaffCompensation {
  id      String @id @default(uuid())
  staffId String @map("staff_id")
  staff   Staff  @relation("CompensationStaff", fields: [staffId], references: [id], onDelete: Cascade)
  period  String // YYYY-MM
  amountCents Int @default(0) @map("amount_cents")
  items   Json   @default("[]") // [{at, kind, amountCents, ref}]

  @@unique([staffId, period])
  @@map("staff_compensation")
}

// --- Chat (milestone 8) ---

// Un thread per controparte (AI, coach, nutrizionista) per ogni cliente.
model ChatThread {
  id            String          @id @default(uuid())
  clientId      String          @map("client_id")
  client        User            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  counterpart   ChatCounterpart
  lastMessageAt DateTime?       @map("last_message_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  messages Message[]

  @@unique([clientId, counterpart])
  @@map("chat_thread")
}

// senderRole: client | coach | nutritionist | head_nutritionist | ai
// meta: instradamento/filtro (es. {matchedFaq}, {routedTo}, {escalated}, {forwardedFrom}).
model Message {
  id           String     @id @default(uuid())
  threadId     String     @map("thread_id")
  thread       ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderRole   String     @map("sender_role")
  senderUserId String?    @map("sender_user_id")
  body         String
  meta         Json?
  sentAt       DateTime   @default(now()) @map("sent_at")

  @@index([threadId, sentAt])
  @@map("message")
}

// --- Area sanitaria (milestone 7) ---

// Visite: la PRIMA è sempre in presenza (vincolo imposto dal modulo, spec sez. 11);
// la televisita è ammessa solo per i controlli successivi.
model Visit {
  id             String      @id @default(uuid())
  clientId       String      @map("client_id")
  client         User        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nutritionistId String      @map("nutritionist_id")
  nutritionist   Staff       @relation("VisitNutritionist", fields: [nutritionistId], references: [id], onDelete: Restrict)
  type           VisitType
  datetime       DateTime
  status         VisitStatus @default(scheduled)
  notes          String? // RISERVATE: solo nutrizionista e capo
  videoRoomId    String?     @map("video_room_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@index([clientId, datetime])
  @@index([nutritionistId, datetime])
  @@map("visit")
}

// Documenti sanitari: contenuto cifrato AES-256-GCM nel database (storage UE).
// L'astrazione permetterà la migrazione a bucket S3 senza cambiare le API.
model Document {
  id           String         @id @default(uuid())
  clientId     String         @map("client_id")
  client       User           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type         DocumentType
  fileName     String         @map("file_name")
  mimeType     String         @map("mime_type")
  sizeBytes    Int            @map("size_bytes")
  data         Bytes // iv (12B) + authTag (16B) + ciphertext
  status       DocumentStatus @default(pending)
  flags        String[]       @default([]) // es. "valore fuori range"
  reviewedById String?        @map("reviewed_by_id")
  reviewedBy   Staff?         @relation("DocumentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote   String?        @map("review_note")
  uploadedAt   DateTime       @default(now()) @map("uploaded_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([clientId, uploadedAt])
  @@index([status])
  @@map("document")
}

// Note cliniche: accesso RISERVATO a nutrizionista assegnato e capo. Mai coach, mai admin.
model ClinicalNote {
  id             String   @id @default(uuid())
  clientId       String   @map("client_id")
  client         User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  nutritionistId String   @map("nutritionist_id")
  nutritionist   Staff    @relation("NoteAuthor", fields: [nutritionistId], references: [id], onDelete: Restrict)
  text           String
  date           DateTime @default(now())

  @@index([clientId, date])
  @@map("clinical_note")
}

// --- Calendario e notifiche (milestone 6) ---

// Segnale "Agenda": eventi singoli e periodi senza dieta.
// I periodi di pausa sospendono l'erogazione ma il monitoraggio continua:
// oltre pause_deviation_trigger scatta il mini-piano (spec sez. 5/8).
model Event {
  id             String    @id @default(uuid())
  clientId       String    @map("client_id")
  client         User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type           EventType
  label          String?
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime  @map("end_date") @db.Date
  mode           EventMode
  planPhaseState String?   @map("plan_phase_state") // before | during | after | mini_plan_active
  startWeightKg  Float?    @map("start_weight_kg") // peso all'inizio della pausa (per il mini-piano)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([clientId, startDate])
  @@map("event")
}

// Eventi di tracciamento (analitici, append-only). Ogni click/interazione del
// prototipo passa da track() → POST /events. Tabella DISACCOPPIATA: nessuna FK
// verso User (userId è una stringa opzionale) così gli eventi restano immutabili
// e sopravvivono alla cancellazione dell'utente (GDPR: no dati sanitari nel data).
// Vedi Metabole_Tracciamento_Dati.md.
model AnalyticsEvent {
  id         String   @id @default(uuid())
  eventId    String   @unique @map("event_id") // UUID lato client per idempotenza sui retry
  name       String // "ui_click" | "view" | ...
  userId     String?  @map("user_id") // dal JWT se presente (nessuna FK)
  session    String? // sessione pre-login (riconciliata alla registrazione)
  refcod     String? // attribuzione commerciale / provvigioni
  phase      String? // "flow" | "app"
  screen     String?
  step       Int?
  data       Json? // payload libero (MAI dati sanitari in chiaro)
  clientTs   BigInt?  @map("client_ts") // timestamp epoch ms dichiarato dal client
  receivedAt DateTime @default(now()) @map("received_at")

  @@index([userId, receivedAt])
  @@index([session, receivedAt])
  @@index([name, receivedAt])
  @@map("analytics_event")
}

// Alert engine (coda avvisi per la coach). Tabella DISACCOPPIATA (clientId/coachId
// come stringhe, nessuna FK) generata e sincronizzata da AlertsService.recompute:
// gli alert la cui condizione non vale più vengono messi a status='resolved'.
// coachId = Staff.id della coach assegnata. Vedi Metabole_Backend_Operazioni §5.
model Alert {
  id        String    @id @default(uuid())
  clientId  String    @map("client_id")
  coachId   String?   @map("coach_id")
  group     String    @map("alert_group") // corpo_misure | aderenza_vita | gusto_mente | agenda_op
  type      String // missing_measurements | weight_gain | plateau | inactive | checkin_skipped | water_low | low_ratings | dropout_risk | event_incoming | escalation_open | milestone
  priority  String // high | med | low
  title     String
  detail    String?
  status    String    @default("open") // open | handled | escalated | resolved
  dueDate   DateTime? @map("due_date") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([coachId, status])
  @@index([clientId, type, status])
  @@map("alert")
}

// Appuntamento in agenda (app coach + cliente). Entità di SCHEDULING generale
// (coach e nutrizionista); la visita clinica dettagliata resta su Visit (fase
// nutrizionista). FK-less: clientId/staffId come stringhe. Vedi Metabole_Backend_Operazioni §6.
model Appointment {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  staffId   String   @map("staff_id")
  staffRole String   @map("staff_role") // coach | nutritionist
  type      String // call | televisit | in_person
  datetime  DateTime
  status    String   @default("scheduled") // scheduled | done | cancelled
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([clientId, datetime])
  @@index([staffId, datetime])
  @@map("appointment")
}

// Notifiche personalizzate (spec sez. 9). userId = destinatario (cliente o staff).
model Notification {
  id           String              @id @default(uuid())
  userId       String              @map("user_id")
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String // checkin_reminder | measurement_reminder | rating_request | pre_event | mini_plan | stall_coach_alert | no_checkin_coach_alert | ...
  payload      Json?
  channel      NotificationChannel @default(inapp)
  scheduledFor DateTime            @map("scheduled_for")
  sentAt       DateTime?           @map("sent_at")
  readAt       DateTime?           @map("read_at")
  createdAt    DateTime            @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@index([userId, type, scheduledFor])
  @@map("notification")
}

// --- Motore a regole (milestone 5) ---

// Protocollo/regola: condizioni sui 5 segnali → azione (menu/tono/timing).
// Il motore usa SOLO regole approved (validazione a monte, spec 7.3).
model Protocol {
  id            String         @id @default(uuid())
  name          String
  type          String // menu_correction | threshold | library | ...
  definition    Json // { priority, conditions: [{field, op, value}], action: {menu, tone, timing, levelDelta, flag} }
  thresholds    Json?
  appliesTo     String?        @map("applies_to") // es. "senza condizioni cliniche"
  status        ProtocolStatus @default(pending)
  authorId      String?        @map("author_id")
  author        Staff?         @relation("ProtocolAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  validatedById String?        @map("validated_by_id")
  validatedBy   Staff?         @relation("ProtocolValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  validatedAt   DateTime?      @map("validated_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  decisions EngineDecision[]

  @@index([status])
  @@map("protocol")
}

// Decisione del motore: loggata e SPIEGABILE (snapshot input + regola applicata).
model EngineDecision {
  id               String    @id @default(uuid())
  clientId         String    @map("client_id")
  client           User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date             DateTime  @db.Date
  inputs           Json // snapshot dei 5 segnali al momento della decisione
  ruleId           String?   @map("rule_id")
  rule             Protocol? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  action           Json // {menu, tone, timing, level, note}
  flaggedForReview Boolean   @default(false) @map("flagged_for_review")
  flagReason       String?   @map("flag_reason")
  reviewedById     String?   @map("reviewed_by_id")
  reviewedAt       DateTime? @map("reviewed_at")
  reviewOutcome    String?   @map("review_outcome") // confirmed | corrected
  reviewNote       String?   @map("review_note")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([clientId, date])
  @@index([flaggedForReview, reviewedAt])
  @@map("engine_decision")
}

// --- Diete, ricette, menu (milestone 4) ---

// Dieta del catalogo: proposta da un nutrizionista, approvata dal capo.
model Diet {
  id           String     @id @default(uuid())
  name         String
  regime       Regime
  style        DietStyle
  mealsPerDay  Int        @map("meals_per_day")
  levels       Json? // es. [{level:1, kcal:1400}, {level:2, kcal:1600}]
  options      Json? // integratori, digiuno intermittente…
  authorId     String?    @map("author_id")
  author       Staff?     @relation("DietAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  status       DietStatus @default(draft)
  approvedById String?    @map("approved_by_id")
  approvedBy   Staff?     @relation("DietApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?  @map("approved_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  dayTemplates DietDayTemplate[]
  menuDays     MenuDay[]

  @@index([status])
  @@index([regime, mealsPerDay, status])
  @@map("diet")
}

model Recipe {
  id             String   @id @default(uuid())
  name           String
  regime         Regime
  mealSlot       MealSlot @map("meal_slot")
  kcal           Int
  ingredients    Json // [{name, qty, unit}]
  cookingMethods Json?    @map("cooking_methods") // [{type: veloce|forno|meal_prep, steps: []}]
  tags           String[] @default([])
  macros         Json? // {protein_g, carbs_g, fat_g}
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  ratings RecipeRating[]

  @@index([regime, mealSlot, active])
  @@map("recipe")
}

// Struttura di una giornata per dieta+livello (rotazione su dayIndex).
model DietDayTemplate {
  id       String @id @default(uuid())
  dietId   String @map("diet_id")
  diet     Diet   @relation(fields: [dietId], references: [id], onDelete: Cascade)
  level    Int
  dayIndex Int    @map("day_index") // 1..N, il menu ruota su N giornate
  meals    Json // [{slot, recipeId}]

  @@unique([dietId, level, dayIndex])
  @@map("diet_day_template")
}

// Giornata di menu erogata alla cliente (2 giorni alla volta).
model MenuDay {
  id           String   @id @default(uuid())
  clientId     String   @map("client_id")
  client       User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  dietId       String   @map("diet_id")
  diet         Diet     @relation(fields: [dietId], references: [id], onDelete: Restrict)
  level        Int      @default(1)
  meals        Json // snapshot [{slot, recipeId, name, kcal}]
  status       String   @default("planned")
  visibleFrom  DateTime @map("visible_from") @db.Date
  sourceRuleId String?  @map("source_rule_id") // valorizzato dal motore (M5)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([clientId, date])
  @@index([clientId, date])
  @@map("menu_day")
}

// Segnale "Gusto": valutazione di una ricetta consumata.
model RecipeRating {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recipeId String   @map("recipe_id")
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  stars    Int // 1–5
  tags     String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, recipeId, date])
  @@index([recipeId])
  @@map("recipe_rating")
}

// Lista spesa per un intervallo di menu (con spunte persistenti).
model ShoppingList {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dateFrom DateTime @map("date_from") @db.Date
  dateTo   DateTime @map("date_to") @db.Date
  items    Json // [{name, qty, unit, checked}]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, dateFrom, dateTo])
  @@map("shopping_list")
}

// --- Segnali (milestone 3): il carburante del motore ---

// Segnale "Corpo": misure inserite ~ogni 2 giorni. Una per giorno.
model Measurement {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  weightKg Float    @map("weight_kg")
  waistCm  Float?   @map("waist_cm")
  hipsCm   Float?   @map("hips_cm")
  thighsCm Float?   @map("thighs_cm")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, date])
  @@index([clientId, date])
  @@map("measurement")
}

// Segnale "Testa": check-in giornaliero (umore obbligatorio, il resto opzionale 1–5).
model DailyCheckin {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  mood     Mood
  energy   Int?
  hunger   Int?
  stress   Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, date])
  @@index([clientId, date])
  @@map("daily_checkin")
}

model WaterLog {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  glasses  Int
  goal     Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, date])
  @@map("water_log")
}

model StepLog {
  id       String   @id @default(uuid())
  clientId String   @map("client_id")
  client   User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  steps    Int
  goal     Int
  source   String?  // manual | healthkit | google_fit (futuro)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([clientId, date])
  @@map("step_log")
}

// Log delle note dello staff sul cliente: ogni salvataggio è una voce
// (testo, autore, data/ora). Non è una nota clinica riservata: è visibile a
// chi gestisce il cliente (coach ecc.).
model ClientNote {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  client    User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  body      String
  authorId  String?  @map("author_id")
  author    Staff?   @relation("ClientNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId, createdAt])
  @@map("client_note")
}

// Traguardi raggiunti (celebrazioni): prima misura, -1/-3/-5 kg, metà strada, obiettivo.
model Milestone {
  id         String   @id @default(uuid())
  clientId   String   @map("client_id")
  client     User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type       String // first_measurement | lost_1kg | lost_3kg | lost_5kg | halfway | goal_reached
  label      String
  achievedAt DateTime @default(now()) @map("achieved_at")

  @@unique([clientId, type])
  @@index([clientId])
  @@map("milestone")
}

// Refresh token (rotazione): salvato solo l'hash, mai il token in chiaro.
model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_token")
}

// Token monouso per verifica email e reset password (salvato hashato).
model ActionToken {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActionTokenType
  tokenHash String          @unique @map("token_hash")
  email     String?         // email di destinazione (per il cambio email)
  expiresAt DateTime        @map("expires_at")
  usedAt    DateTime?       @map("used_at")
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([userId, type])
  @@map("action_token")
}

// Soglie e parametri del motore, configurabili a runtime (mai hardcodati).
// Valori iniziali: Appendice A della specifica.
model ConfigParam {
  key         String          @id
  value       String
  type        ConfigParamType @default(number)
  description String?
  updatedById String?         @map("updated_by_id")
  updatedBy   User?           @relation("ConfigUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("config_param")
}

// Provvigione accantonata: creata quando al pagamento manca lo staff assegnato
// (es. cliente che paga la visita prima di avere il nutrizionista). Viene pagata
// quando lo staff viene assegnato dal backoffice (o annullata se non dovuta).
model PendingCommission {
  id              String    @id @default(uuid())
  paymentId       String    @map("payment_id")
  clientId        String    @map("client_id")
  role            String // coach | manager_coach | nutritionist | head_nutritionist
  amountCents     Int       @map("amount_cents")
  status          String    @default("pending") // pending | paid | cancelled
  resolvedStaffId String?   @map("resolved_staff_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  resolvedAt      DateTime? @map("resolved_at")

  @@index([clientId, status])
  @@map("pending_commission")
}

// Buono sconto: percentuale o importo fisso, con tetto di utilizzi totali e per
// cliente. Il cliente lo inserisce al momento dell'acquisto.
model DiscountCode {
  id           String    @id @default(uuid())
  code         String    @unique // codice inserito dal cliente (maiuscolo)
  type         String // percent | fixed
  value        Int // percent (es. 10) oppure importo in centesimi
  maxTotalUses Int?      @map("max_total_uses") // null = illimitato
  maxPerClient Int       @default(1) @map("max_per_client")
  usedCount    Int       @default(0) @map("used_count")
  active       Boolean   @default(true)
  expiresAt    DateTime? @map("expires_at")
  createdById  String?   @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  redemptions DiscountRedemption[]

  @@map("discount_code")
}

model DiscountRedemption {
  id          String       @id @default(uuid())
  codeId      String       @map("code_id")
  code        DiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  clientId    String       @map("client_id")
  paymentId   String?      @map("payment_id")
  amountCents Int          @map("amount_cents") // sconto applicato
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([codeId, clientId])
  @@map("discount_redemption")
}

// Modello email modificabile dall'admin. subject/bodyHtml usano segnaposto {{var}}.
// Se manca o è disattivato, si usa il testo predefinito (i18n).
model EmailTemplate {
  key         String   @id // es. payment_receipt, password_reset, ...
  name        String
  subject     String
  bodyHtml    String   @map("body_html")
  active      Boolean  @default(true)
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("email_template")
}

/** Template HTML dei PDF inviati ai clienti (ricevuta, report mensile), modificabili da admin. */
model PdfTemplate {
  key         String   @id // 'receipt', 'monthly_report'
  name        String
  html        String
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("pdf_template")
}

// Log di ogni email tentata (per verificare gli invii).
model EmailLog {
  id          String   @id @default(uuid())
  to          String
  templateKey String?  @map("template_key")
  subject     String
  status      String // sent | failed | skipped
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("email_log")
}

// Matrice permessi del backoffice: ruolo × sezione → vede / gestisce.
// I default arrivano dal seed (specifica sez. 4); l'admin li modifica a runtime.
// Ruoli personalizzati: etichetta + colore + ruolo di sistema di base (da cui
// ereditano i permessi reali). Aggiunti/rimossi dall'admin dal backoffice.
model CustomRole {
  key         String   @id
  label       String
  color       String?
  baseRole    Role     @map("base_role")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]

  @@map("custom_role")
}

model RolePagePermission {
  role        String // ruolo di sistema o chiave di un ruolo personalizzato
  pageKey     String   @map("page_key")
  canView     Boolean  @default(false) @map("can_view")
  canManage   Boolean  @default(false) @map("can_manage")
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@id([role, pageKey])
  @@map("role_page_permission")
}

// Audit log: ogni accesso/azione su dati sanitari e ogni decisione del motore.
model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String // es. "user.login", "config_param.update", "health_data.read"
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}
