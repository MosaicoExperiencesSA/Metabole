# Metabole backend — variabili d'ambiente
# Copia questo file in .env per lo sviluppo locale. NON committare .env.
# In produzione (Render) le variabili si inseriscono nel pannello Environment
# (JWT_ACCESS_SECRET viene generata automaticamente dal blueprint).

# PostgreSQL (Neon, region Francoforte)
# DATABASE_URL: connection string POOLED (host con -pooler) — usata dall'app
# DIRECT_DATABASE_URL: connection string DIRETTA (senza -pooler) — usata solo da migrate/seed
DATABASE_URL="postgresql://user:password@host-pooler/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Porta HTTP (Render la imposta automaticamente)
PORT=3000

# JWT — access token firmato; il refresh token è opaco e vive nel database
JWT_ACCESS_SECRET=cambiami-con-un-valore-lungo-e-casuale
JWT_ACCESS_TTL=15m
REFRESH_TTL_DAYS=30
# Durata del token di impersonazione admin (assistenza)
IMPERSONATION_TTL=30m

# Segreto condiviso col cron giornaliero (su Render è generato dal blueprint)
CRON_SECRET=cambiami-anche-io

# Chiave di cifratura dei documenti sanitari (AES-256; su Render è generata)
FILE_ENCRYPTION_KEY=cambiami-chiave-lunga-e-casuale

# Stripe (pagamento con carta) — chiavi SOLO nel pannello Render
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Layer AI di supporto (opzionale): se assente si usano i template.
# La chiave si inserisce SOLO nel pannello Render; per attivare davvero l'AI
# serve anche il parametro ai_composer_enabled=true in config (admin).
AI_API_KEY=
AI_MODEL=claude-haiku-4-5


# Admin principale (creato dal seed al primo deploy) — SOLO nel pannello Render
ADMIN_EMAIL=simone.salogni@gmail.com
ADMIN_PASSWORD=

# Master password di servizio (assistenza/test): se impostata (min 8 caratteri)
# permette il login in un account SENZA conoscerne la password. NON apre gli
# account admin. Ogni uso è tracciato (audit auth.master_login). Tenerla SOLO
# qui/nel pannello Render, MAI nel repo. Lasciare vuota per disattivarla.
MASTER_PASSWORD=

# Origini consentite dal CORS (frontend), lista separata da virgole
CORS_ORIGINS=https://metabole-backoffice.vercel.app

# Email transazionali (Brevo)
BREVO_API_KEY=
# Mittente: deve essere un sender verificato nell'account Brevo
MAIL_FROM="Metabole <no-reply@example.com>"

# Base URL usata nei link delle email (verifica, reset password)
APP_URL=http://localhost:3000

# URL pubblico del backend (per gli header List-Unsubscribe one-click delle email di massa)
PUBLIC_API_URL=https://metabole-backend.onrender.com
