# URL base delle API Metabole (senza /api/v1 finale).
# In sviluppo: http://localhost:3000
# In produzione (Vercel): https://metabole-backend.onrender.com
VITE_API_URL=https://metabole-backend.onrender.com

# Notifiche push: lasciare spento finché Firebase (google-services.json) non è
# configurato. Su Android, registrare le push senza Firebase può chiudere l'app.
# Quando Firebase è pronto: VITE_ENABLE_PUSH=true e ricompilare l'APK.
VITE_ENABLE_PUSH=false
