{
  "name": "metabole-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "App Metabole — unica per cliente, coach e nutrizionista, smistata per ruolo (React + Vite + Capacitor: web, Android, iOS)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "android:init": "npm run build && cap add android",
    "android:sync": "npm run build && cap sync android && npm run android:widget && npm run android:steps && npm run android:push && npm run android:icon",
    "android:widget": "node ../scripts/install-widget.mjs",
    "android:steps": "node ../scripts/install-steps.mjs",
    "android:push": "node ../scripts/install-push.mjs",
    "android:icon": "node ../scripts/install-icon.mjs",
    "android:open": "cap open android"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/push-notifications": "^6.0.5",
    "@capacitor/status-bar": "^6.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.6"
  }
}
