# Copia questo file in ".env" (stessa cartella) e incolla la tua chiave vera.
# Il file .env è ignorato da git: la chiave NON finisce mai nel repo.
#   cp .env.example .env
# poi apri .env e sostituisci il valore qui sotto.

ELEVENLABS_API_KEY=sk_incolla_qui_la_tua_chiave_vera

